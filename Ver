-- CHUNKED player discovery. THE ~1s ESP stutter root cause: in AoT the Characters folder
-- holds EVERY player in the server (not just nearby ones), so reading each one's .Name in a
-- single burst every scan = 30-40 Matcha bridge round-trips back-to-back, which freezes the
-- cooperative scheduler for a frame each scan — a steady tick that's there even when you're
-- alone (the folder is full server-wide) and only when ESP is on (this is the only thing
-- gated by it). Fix: start a fresh pass every ESP_SCAN_INTERVAL, then process only a few
-- characters PER TICK (each .Name read pcall'd) so the burst is spread over several frames
-- and never blocks the render loop. NEVER compare shims with ~= (o.model ~= model is always
-- true in Matcha → would restart the position smoothing every scan); just refresh o.model.
local _pKids, _pIdx, _pPresent, _pNextAt = nil, 0, nil, 0
local ESP_SCAN_CHUNK = 5
local function espScanStep(nowc)
    if not _pKids then
        if nowc < _pNextAt then return end          -- wait out the gap between passes
        local world = Workspace:FindFirstChild("World")
        local chars = world and world:FindFirstChild("Characters")
        if not chars then
            for key, o in pairs(PLAYER_ESP.Objects) do removeEspObj(o); PLAYER_ESP.Objects[key] = nil end
            _pNextAt = nowc + ESP_SCAN_INTERVAL
            return
        end
        local ok, kids = pcall(function() return chars:GetChildren() end)
        if not ok or type(kids) ~= "table" then _pNextAt = nowc + ESP_SCAN_INTERVAL; return end
        _pKids, _pIdx, _pPresent = kids, 0, {}
    end
    local localName = LocalPlayer.Name
    local stop = min(_pIdx + ESP_SCAN_CHUNK, #_pKids)
    for i = _pIdx + 1, stop do
        local model = _pKids[i]
        local nm
        pcall(function() nm = model.Name end)
        if nm and nm ~= localName then
            _pPresent[nm] = true
            local o = PLAYER_ESP.Objects[nm]
            if not o then
                local okM, newO = pcall(makeEspObj, model)
                if okM and newO then PLAYER_ESP.Objects[nm] = newO end
            else
                o.model = model   -- refresh ref only; drawPlayer self-heals o.hrp + snaps on respawn
            end
        end
    end
    _pIdx = stop
    if _pIdx >= #_pKids then                          -- pass complete → prune departed, schedule next
        for key, o in pairs(PLAYER_ESP.Objects) do
            if not _pPresent[key] then removeEspObj(o); PLAYER_ESP.Objects[key] = nil end
        end
        _pKids, _pPresent = nil, nil
        _pNextAt = nowc + ESP_SCAN_INTERVAL
    end
end

-- CHUNKED titan discovery — same spread-the-burst fix as espScanStep (stableInstanceKey
-- reads .Address per titan, another per-scan bridge burst). A few titans per tick.
local _tKids, _tIdx, _tPresent, _tNextAt = nil, 0, nil, 0
local TITAN_SCAN_CHUNK = 5
local function titanScanStep(nowc)
    if not _tKids then
        if nowc < _tNextAt then return end
        local world = Workspace:FindFirstChild("World")
        local titans = world and world:FindFirstChild("Titans")
        if not titans then
            for key, o in pairs(TITAN_ESP.Objects) do removeTitanObj(o); TITAN_ESP.Objects[key] = nil end
            _tNextAt = nowc + TITAN_SCAN_INTERVAL
            return
        end
        local ok, kids = pcall(function() return titans:GetChildren() end)
        if not ok or type(kids) ~= "table" then _tNextAt = nowc + TITAN_SCAN_INTERVAL; return end
        _tKids, _tIdx, _tPresent = kids, 0, {}
    end
    local stop = min(_tIdx + TITAN_SCAN_CHUNK, #_tKids)
    for i = _tIdx + 1, stop do
        local model = _tKids[i]
        local key = stableInstanceKey(model, i)
        _tPresent[key] = true
        local o = TITAN_ESP.Objects[key]
        if not o then
            local okM, newO = pcall(makeTitanObj, model, key)
            if okM and newO then TITAN_ESP.Objects[key] = newO end
        else
            o.model = model
        end
    end
    _tIdx = stop
    if _tIdx >= #_tKids then
        for key, o in pairs(TITAN_ESP.Objects) do
            if not _tPresent[key] then removeTitanObj(o); TITAN_ESP.Objects[key] = nil end
        end
        _tKids, _tPresent = nil, nil
        _tNextAt = nowc + TITAN_SCAN_INTERVAL
    end
end

local function markPlayerCull(myPos)
    local maxRender = PLAYER_ESP.MaxRender or 22
    local count = 0
    for _, o in pairs(PLAYER_ESP.Objects) do
        o._culled = false
        count = count + 1
    end
    if count <= maxRender or not myPos then return end

    local list = {}
    for _, o in pairs(PLAYER_ESP.Objects) do
        local root = o.hrp
        if not root or not root.Parent then
            root = getRoot(o.model)
            o.hrp = root
        end
        if root then
            local ok, pos = pcall(function() return root.Position end)
            if ok and pos then
                list[#list + 1] = { o = o, d = (pos - myPos).Magnitude }
            end
        end
    end

    if #list > maxRender then
        table.sort(list, function(a, b) return a.d < b.d end)
        for i = maxRender + 1, #list do
            list[i].o._culled = true
        end
    end
end

local function drawPlayer(o, myPos, vpW, vpH, col, colVer, dt)
    if o._culled then hideEspObj(o); return end

    local model = o.model
    if not model or not model.Parent then hideEspObj(o); return end

    local root = o.hrp
    if not root or not root.Parent then
        root = getRoot(model)
        o.hrp = root
    end
    if not root then hideEspObj(o); return end

    -- Frame-rate-independent exponential smoothing on scalar components. Glides
    -- the low-rate server position into smooth motion without allocating a
    -- Vector3 per frame (the old per-frame :Lerp was the main GC/stutter source);
    -- snaps on big jumps (respawn / teleport) so it never trails across the map.
    local rp = root.Position
    local sx, sy, sz = o.sx, o.sy, o.sz
    if sx then
        local jx, jy, jz = rp.X - sx, rp.Y - sy, rp.Z - sz
        if jx*jx + jy*jy + jz*jz > 1600 then            -- >40 studs → snap
            sx, sy, sz = rp.X, rp.Y, rp.Z
        else
            local a = 1 - exp(-ESP_SMOOTH_K * (dt or 0.007))
            sx, sy, sz = sx + jx*a, sy + jy*a, sz + jz*a
        end
    else
        sx, sy, sz = rp.X, rp.Y, rp.Z
    end
    o.sx, o.sy, o.sz = sx, sy, sz
    local pos = V3(sx, sy, sz)

    local dist = myPos and (pos - myPos).Magnitude or nil
    if dist and dist > PLAYER_ESP.MaxDistance then hideEspObj(o); return end

    local headS, onHead = project(pos + PLAYER_HEAD_OFF)
    local footS, onFoot = project(pos - PLAYER_FOOT_OFF)
    if not (headS and footS) or (not onHead and not onFoot) then hideEspObj(o); return end

    o.cache.hidden = nil
    if o.cache.colVer ~= colVer then
        o.cache.colVer = colVer
        o.box.Color = col
        o.name.Color = col
        o.dist.Color = col
        o.tracer.Color = col
    end

    local topY = min(headS.Y, footS.Y)
    local bottomY = max(headS.Y, footS.Y)
    local boxH = max(6, bottomY - topY)
    local boxW = boxH * 0.42
    local centerX = (headS.X + footS.X) * 0.5
    local boxX = centerX - boxW * 0.5

    if PLAYER_ESP.ShowBox and boxH > 0 then
        o.box.Position = rv2(boxX, topY)
        o.box.Size = rv2(boxW, boxH)
        setVis(o, o.box, "boxVis", true)
    else
        setVis(o, o.box, "boxVis", false)
    end

    if not o.displayName then
        local fn = model:GetAttribute("FirstName")
        if fn == nil then
            local fc = model:FindFirstChild("FirstName")
            if fc then fn = fc.Value end
        end
        if type(fn) == "string" and fn ~= "" then
            o.displayName = fn .. " (" .. model.Name .. ")"
        end
    end

    local nameStr = PLAYER_ESP.ShowName and (o.displayName or model.Name) or ""
    if nameStr ~= "" then
        o.name.Position = rv2(centerX, topY - 16)
        if o.cache.nameTxt ~= nameStr then
            o.cache.nameTxt = nameStr
            o.name.Text = nameStr
        end
        setVis(o, o.name, "nameVis", true)
    else
        setVis(o, o.name, "nameVis", false)
    end

    local belowY = bottomY + 1
    local showHp = PLAYER_ESP.ShowHealthBar and boxH > 4
    if showHp then
        -- Health changes slowly; re-read the Humanoid at ~12Hz instead of every frame (each
        -- read is Health + MaxHealth + a Parent check = ~3 bridge round-trips/player). The
        -- bar geometry below still applies the cached pct EVERY frame so it tracks the box.
        local nowc = os.clock()
        if not o._hpAt or (nowc - o._hpAt) > 0.08 then
            o._hpAt = nowc
            local hum = o.hum
            if not hum or not hum.Parent then
                hum = model:FindFirstChildWhichIsA("Humanoid")
                o.hum = hum
            end
            local hp, maxHp = 1, 1
            if hum then
                hp = tonumber(hum.Health) or hp
                maxHp = tonumber(hum.MaxHealth) or maxHp
            end
            o._hpPct   = maxHp > 0 and max(0, min(1, hp / maxHp)) or 0
            o._hpStr   = tostring(floor(hp + 0.5))
            o._hpColor = Color3.fromRGB(floor(255 * (1 - o._hpPct)), floor(220 * o._hpPct), 60)
        end
        local pct = o._hpPct or 0
        local barW = 3
        local fillH = boxH * pct
        o.hpFill.Position = rv2(boxX - barW - 3, topY + (boxH - fillH))
        o.hpFill.Size = rv2(barW, fillH)
        o.hpFill.Color = o._hpColor
        setVis(o, o.hpFill, "hpFillVis", true)
    else
        setVis(o, o.hpFill, "hpFillVis", false)
    end

    local distInt = (PLAYER_ESP.ShowDistance and dist) and floor(dist + 0.5) or nil
    if distInt then
        o.dist.Position = rv2(centerX, belowY)
        if o.cache.distInt ~= distInt then        -- build the string ONLY when the integer changes (no per-frame concat → no GC churn)
            o.cache.distInt = distInt
            o.dist.Text = distInt .. "m"
        end
        setVis(o, o.dist, "distVis", true)
        belowY = belowY + 13
    else
        setVis(o, o.dist, "distVis", false)
    end

    if showHp then
        o.hpNum.Position = rv2(centerX, belowY)
        local hpStr = o._hpStr or "?"
        if o.cache.hpNumTxt ~= hpStr then
            o.cache.hpNumTxt = hpStr
            o.hpNum.Text = hpStr
        end
        o.hpNum.Color = o._hpColor or Color3.fromRGB(60, 220, 80)
        setVis(o, o.hpNum, "hpNumVis", true)
    else
        setVis(o, o.hpNum, "hpNumVis", false)
    end

    if PLAYER_ESP.ShowTracer then
        o.tracer.From = rv2(vpW * 0.5, vpH)
        o.tracer.To = rv2(centerX, bottomY)
        setVis(o, o.tracer, "tracerVis", true)
    else
        setVis(o, o.tracer, "tracerVis", false)
    end
end

local function espUpdate(dt)
    if not Features.PlayerESP then
        for _, o in pairs(PLAYER_ESP.Objects) do hideEspObj(o) end
        return
    end

    local myPos = localRootPos()
    local vpW, vpH = viewportSize()
    local col = PLAYER_ESP.Color
    local colVer = PLAYER_ESP._colVer or 0

    markPlayerCull(myPos)
    for _, o in pairs(PLAYER_ESP.Objects) do
        local ok = pcall(drawPlayer, o, myPos, vpW, vpH, col, colVer, dt)
        if not ok then hideEspObj(o) end
    end
end

local function drawTitan(o, myPos)
    local model = o.model
    if not model or not model.Parent then hideTitanObj(o); return end

    local root = o.hrp
    if not root or not root.Parent then
        root = getRoot(model)
        o.hrp = root
    end
    if not root then hideTitanObj(o); return end

    local pos = root.Position
    local dist = myPos and (pos - myPos).Magnitude or nil
    if dist and dist > TITAN_ESP.MaxDistance then hideTitanObj(o); return end

    local headS, onHead = project(pos + TITAN_HEAD_OFF)
    local footS, onFoot = project(pos - TITAN_FOOT_OFF)
    if not (headS and footS) or (not onHead and not onFoot) then hideTitanObj(o); return end

    o.cache.hidden = nil
    local topY = min(headS.Y, footS.Y)
    local bottomY = max(headS.Y, footS.Y)
    local boxH = max(8, bottomY - topY)
    local boxW = boxH * 0.50
    local centerX = (headS.X + footS.X) * 0.5
    local boxX = centerX - boxW * 0.5

    o.box.Position = rv2(boxX, topY)
    o.box.Size = rv2(boxW, boxH)
    o.box.Color = TITAN_ESP.Color
    setVis(o, o.box, "boxVis", true)

    local label = "Titan" .. (dist and ("  " .. floor(dist + 0.5) .. "m") or "")
    o.name.Position = rv2(centerX, topY - 16)
    o.name.Color = TITAN_ESP.Color
    if o.cache.nameTxt ~= label then
        o.cache.nameTxt = label
        o.name.Text = label
    end
    setVis(o, o.name, "nameVis", true)

    local napeHp = tonumber(model:GetAttribute("NapeHealth"))
    if napeHp and boxH > 4 then
        o.maxNape = max(o.maxNape or napeHp, napeHp)
        local pct = (o.maxNape > 0) and max(0, min(1, napeHp / o.maxNape)) or 0
        local barW = 3
        local fillH = boxH * pct
        local hpColor = Color3.fromRGB(floor(255 * (1 - pct)), floor(220 * pct), 60)
        o.hpFill.Position = rv2(boxX - barW - 3, topY + (boxH - fillH))
        o.hpFill.Size = rv2(barW, fillH)
        o.hpFill.Color = hpColor
        setVis(o, o.hpFill, "hpFillVis", true)

        local hpText = "Nape " .. floor(napeHp + 0.5)
        o.hpNum.Position = rv2(centerX, bottomY + 1)
        o.hpNum.Color = hpColor
        if o.cache.hpNumTxt ~= hpText then
            o.cache.hpNumTxt = hpText
            o.hpNum.Text = hpText
        end
        setVis(o, o.hpNum, "hpNumVis", true)
    else
        setVis(o, o.hpFill, "hpFillVis", false)
        setVis(o, o.hpNum, "hpNumVis", false)
    end

    if Features.TitanNapeMarker then
        local napePos
        if not Features.NapeFollow then
            local dp = model:FindFirstChild("DamagePoints")
            local np = dp and dp:FindFirstChild("Nape")
            if np then napePos = np.Position end
        end
        if not napePos then
            local head = model:FindFirstChild("Head")
            napePos = head and head.Position or (pos + V3(0, 5, 0))
        end
        local ns, onN = project(napePos)
        if ns and onN then
            o.nape.Position = rv2(ns.X, ns.Y)
            o.nape.Radius = dist and max(3, min(11, 700 / max(1, dist))) or 6
            o.nape.Color = TITAN_ESP.NapeColor
            setVis(o, o.nape, "napeVis", true)
        else
            setVis(o, o.nape, "napeVis", false)
        end
    else
        setVis(o, o.nape, "napeVis", false)
    end
end

local function titanEspUpdate()
    if not Features.TitanESP then
        for _, o in pairs(TITAN_ESP.Objects) do hideTitanObj(o) end
        return
    end

    local myPos = localRootPos()
    for _, o in pairs(TITAN_ESP.Objects) do
        local ok = pcall(drawTitan, o, myPos)
        if not ok then hideTitanObj(o) end
    end
end

local function freeEspPools()
    for key, o in pairs(PLAYER_ESP.Objects) do
        removeEspObj(o)
        PLAYER_ESP.Objects[key] = nil
    end
    for key, o in pairs(TITAN_ESP.Objects) do
        removeTitanObj(o)
        TITAN_ESP.Objects[key] = nil
    end
end

GUI.StopEspLoops = function()
    local state = _G.__VERFALL_MATCHA_ESP
    if state then state.stop = true end
    if state and state.teardown then
        pcall(state.teardown)
    else
        freeEspPools()
        _G.__VERFALL_MATCHA_ESP = nil
    end
end

GUI.StartEspLoops = function()
    local old = _G.__VERFALL_MATCHA_ESP
    if old then
        if old.teardown then
            pcall(old.teardown)
        else
            old.stop = true
            freeEspPools()
        end
    end

    local state = { stop = false }
    _G.__VERFALL_MATCHA_ESP = state
    state.teardown = function()
        if state._freed then return end
        state.stop = true
        state._freed = true
        if _G.__VERFALL_MATCHA_ESP == state then
            _G.__VERFALL_MATCHA_ESP = nil
        end
        freeEspPools()
    end

    task.spawn(function()
        -- Discovery runs as CHUNKED steppers (espScanStep / titanScanStep): each 20Hz tick
        -- processes only a few targets, so the server-wide folder read is spread across frames
        -- and never blocks the render loop in one burst (that burst was the steady ~1s stutter).
        -- They self-pace a fresh pass every ESP_SCAN_INTERVAL via their own _pNextAt/_tNextAt.
        while GUI.Running and _G.__VERFALL_MATCHA_ESP == state and not state.stop do
            local nowc = os.clock()
            if Features.PlayerESP then pcall(espScanStep, nowc) end
            if Features.TitanESP then pcall(titanScanStep, nowc) end
            task.wait(0.05)
        end
    end)

    task.spawn(function()
        local interval = 1 / ESP_RENDER_HZ
        local last = os.clock()
        while GUI.Running and _G.__VERFALL_MATCHA_ESP == state and not state.stop do
            local now = os.clock(); local dt = now - last; last = now
            pcall(espUpdate, dt)
            pcall(titanEspUpdate)
            task.wait(interval)
        end
    end)
end

