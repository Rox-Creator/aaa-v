-- Format a number compactly: trim trailing zeros, show decimals if < 1
local function fmtNum(n)
    if n == math.floor(n) then return tostring(math.floor(n)) end
    local s = string.format("%.3f", n)
    s = s:gsub("0+$", ""):gsub("%.$", "")
    return s
end


