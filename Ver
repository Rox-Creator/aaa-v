-- Nape Follow: titan Nape + Eye parts get teleported to player + scaled up.
-- Confirmed working 2026-06-08. Single user-controllable value (NapeFollowRange).
restoreNapeFollow = function()
    if Pins.NapeFollow then Pins.NapeFollow:Disconnect(); Pins.NapeFollow = nil end
    -- Put every nape/eye we touched back to normal so the extender actually turns OFF
    -- (un-anchor, restore original size, re-enable welds so the titan reclaims it).
    for part, origSize in pairs(Pins.NapeOriginals or {}) do
        pcall(function()
            part.Anchored = false
            part.CanCollide = false
            part.CanTouch = true
            part.CanQuery = true
            if origSize then part.Size = origSize end
            for _, j in ipairs(part:GetChildren()) do
                if j:IsA("WeldConstraint") or j:IsA("Weld") or j:IsA("Motor6D") then
                    j.Enabled = true
                end
            end
        end)
    end
    Pins.NapeOriginals = {}
    -- Restore any limbs the "always nape" pass shrank (in case the extender was turned
    -- off mid-swing, before the falling-edge restore could run).
    for part, sz in pairs(Pins.LimbOriginals or {}) do
        pcall(function() part.Size = sz end)
    end
    Pins.LimbOriginals = {}
end

