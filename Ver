    { "RunSpeed", "Run Speed" },            { "FirearmRange", "Musket Range" },
    { "OdmHookVeloGain", "Hook Velo Gain" },{ "OdmPassiveVeloGain", "Passive Velo Gain" },
    { "ActionSpeed", "Action Speed" },
}
-- The script's default pin value for each buff (matches the BuffsState init + resetConfig).
-- Shown as each box's tooltip and restored by the "Reset Defaults" button.
local ACK_DEFAULTS = {
    HookRange = 15, GasConservation = 1, ReloadSpeed = 1.5, OdmVeloCap = 10,
    RunSpeed = 11, FirearmRange = 100, OdmHookVeloGain = 10, OdmPassiveVeloGain = 10,
    ActionSpeed = 2,
}
-- Typing only STORES the value now (no auto-pin). Nothing touches your character until you
-- press "Pin Buffs". We keep the box objects so Reset can refresh their displayed text.
local ackBoxes = {}
local function ackStore(key, s)
    local n = tonumber(s)
    if n and n > 0 then
        local b = BuffsState[key]
        if b then b.target = math.min(n, b.max or 100000) end
    end
end
local function ackSetBoxText(key, s)
    local box = ackBoxes[key]; if not box then return end
    if not pcall(function() box:Set(s) end) then pcall(function() box:SetValue(s) end) end
end
-- Per-number pin: each buff gets its own Pin button right under its box (one-shot apply).
local function ackPin(key, label)
    local ok = pinAttrOnce(key, key)
    Lib:Notify("Ackerman", ok and ("Pinned " .. label .. " = " .. fmtNum(BuffsState[key].target))
        or "ClientInformation not found — join a round first", 2, ok and "success" or "warning")
end
for _, e in ipairs(ACK_BUFFS) do
    local key, label = e[1], e[2]
    if BuffsState[key] then
        local def = ACK_DEFAULTS[key] or BuffsState[key].target
        local box = secAck:Textbox(label, fmtNum(BuffsState[key].target), function(s) ackStore(key, s) end)
            :Tooltip("default: " .. fmtNum(def))
        ackBoxes[key] = box
        -- Inline pin (forked lib adds :Pin -> a pin button on the box's right edge). Guarded so
        -- the upstream fallback lib (no :Pin) won't error; it just won't show a pin then.
        pcall(function() box:Pin(function() ackPin(key, label) end) end)
    end
end
