    field=C3(36,34,40), soft=C3(50,48,56), text=C3(228,228,234), muted=C3(122,120,130),
    dim=C3(80,78,88), red=C3(222,68,74), green=C3(82,212,122), yellow=C3(240,202,72), blue=C3(100,176,255),
