-- Titan Anti-Hitbox + No-Attack (part-based, ported from Verfall Old — the proven method).
-- Each titan MODEL holds a "Hitboxes" folder (LeftGrab/RightGrab/LeftStomp/RightStomp/Bite)
-- and a "Detectors" folder. We shrink + kill collision/touch on the relevant parts.
-- Driven by Titans.ChildAdded (each titan as it spawns) + an immediate pass over titans
-- already present, and fully restored when the switches go off.
local TITAN_TINY = Vector3.new(0.01, 0.01, 0.01)

local function shouldDisableHitbox(partName)
    if (partName == "LeftGrab" or partName == "RightGrab") and Features.NoGrab then return true end
    if (partName == "LeftStomp" or partName == "RightStomp") and Features.NoStomp then return true end
    if partName == "Bite" and Features.NoBite then return true end
    return false
end

local function anyTitanFeatureOn()
    return Features.NoGrab or Features.NoStomp or Features.NoBite or Features.NoAttack
end

-- Disable a part (snapshotting its originals once) or restore it. `want` = should be off.
local function setPart(store, part, want)
    if want then
        if not store[part] then
            local ok, snap = pcall(function()
                return { Size = part.Size, CanCollide = part.CanCollide, CanTouch = part.CanTouch }
            end)
            store[part] = ok and snap or { Size = TITAN_TINY, CanCollide = false, CanTouch = false }
        end
        pcall(function() part.CanCollide = false end)
        pcall(function() part.CanTouch  = false end)
        pcall(function() part.Size      = TITAN_TINY end)
    elseif store[part] then
        local snap = store[part]
        pcall(function() part.CanCollide = snap.CanCollide end)
        pcall(function() part.CanTouch  = snap.CanTouch end)
        pcall(function() part.Size      = snap.Size end)
        store[part] = nil
    end
end

-- Sync ONE titan's hitbox + detector parts to the current toggle state.
local function processTitan(titan)
    local hb = titan:FindFirstChild("Hitboxes")
    if hb then
        for _, part in ipairs(hb:GetChildren()) do
            if part:IsA("BasePart") then setPart(Pins.HitboxOriginals, part, shouldDisableHitbox(part.Name)) end
        end
    end
    local dets = titan:FindFirstChild("Detectors")
    if dets then
        for _, part in ipairs(dets:GetChildren()) do
            if part:IsA("BasePart") then setPart(Pins.DetectorOriginals, part, Features.NoAttack) end
        end
    end
end

local function processAllTitans()
    local world = Workspace:FindFirstChild("World")
    local titans = world and world:FindFirstChild("Titans")
    if not titans then return end
    for _, titan in ipairs(titans:GetChildren()) do pcall(processTitan, titan) end
end

-- ChildAdded hook so each new titan gets handled the moment it spawns. Re-applied a few
-- times over the first ~2s because a titan's Hitboxes/Detectors parent a frame or two
-- after the model itself (and to beat any immediate re-enable on spawn).
local TitanConn, TitanFolder = nil, nil
local function unhookTitans()
    if TitanConn then pcall(function() TitanConn:Disconnect() end); TitanConn = nil end
    TitanFolder = nil
end
local function hookTitans()
    local world = Workspace:FindFirstChild("World")
    local titans = world and world:FindFirstChild("Titans")
    if not titans then return end
    if titans == TitanFolder and TitanConn then return end  -- already hooked to this folder
    unhookTitans()
    TitanFolder = titans
    local ok, conn = pcall(function()
        return titans.ChildAdded:Connect(function(titan)
            for _, d in ipairs({ 0.1, 0.5, 1.0, 2.0 }) do
                task.delay(d, function()
                    if anyTitanFeatureOn() then pcall(processTitan, titan) end
                end)
            end
        end)
    end)
    if ok and conn then TitanConn = conn else TitanFolder = nil end
end

-- Restore every part we touched (covers titans no longer in the tree too) and clear.
local function restoreAllTitanParts()
    for part, snap in pairs(Pins.HitboxOriginals) do
        pcall(function() part.CanCollide = snap.CanCollide; part.CanTouch = snap.CanTouch; part.Size = snap.Size end)
    end
    Pins.HitboxOriginals = {}
    for part, snap in pairs(Pins.DetectorOriginals) do
        pcall(function() part.CanCollide = snap.CanCollide; part.CanTouch = snap.CanTouch; part.Size = snap.Size end)
    end
    Pins.DetectorOriginals = {}
end

-- CONTINUOUS re-apply. The server periodically re-enables titan hitboxes (re-replicates
-- their real size back, especially on titan state changes/attacks). Event-driven apply
-- alone decays — the disable "stops working after a while". This Heartbeat keeps
-- re-disabling every frame so the server can never win the race.
local function startTitanLoop()
    if Pins.AntiTitanLoop then return end
    local accum = 0
    Pins.AntiTitanLoop = RunService.Heartbeat:Connect(function(dt)
        if not anyTitanFeatureOn() then return end
        -- Throttle to ~20Hz. The server re-enables hitboxes over SECONDS, so re-disabling
        -- 20x/sec wins the race just as well as 60x/sec at a third of the per-frame cost.
        accum = accum + (dt or 0.016)
        if accum < 0.05 then return end
        accum = 0
        pcall(processAllTitans)
    end)
end
local function stopTitanLoop()
    if Pins.AntiTitanLoop then pcall(function() Pins.AntiTitanLoop:Disconnect() end); Pins.AntiTitanLoop = nil end
end

-- Single entry point for ALL titan toggles (NoGrab/NoStomp/NoBite/NoAttack).
local function syncTitans()
    if anyTitanFeatureOn() then
        hookTitans()        -- apply to new titans on spawn
        processAllTitans()  -- apply to titans already present; restore any type just turned off
        startTitanLoop()    -- keep re-applying every frame so server re-enables can't stick
    else
        stopTitanLoop()
        unhookTitans()
        restoreAllTitanParts()  -- everything off → undo it all
    end
end

