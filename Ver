        if type(b.gasConservation) == "boolean" then Features.GasConservation = b.gasConservation end
        if type(b.reloadSpeed)     == "boolean" then Features.ReloadSpeed     = b.reloadSpeed end
        if type(b.odmVeloCap)      == "boolean" then Features.OdmVeloCap      = b.odmVeloCap end
        if type(b.runSpeed)        == "boolean" then Features.RunSpeed        = b.runSpeed end
        if type(b.noGrab)          == "boolean" then Features.NoGrab          = b.noGrab end
        if type(b.noStomp)         == "boolean" then Features.NoStomp         = b.noStomp end
        if type(b.noBite)          == "boolean" then Features.NoBite          = b.noBite end
        if type(b.napeFollow)      == "boolean" then Features.NapeFollow      = b.napeFollow end
        if type(b.extendNape)      == "boolean" then Features.ExtendNape      = b.extendNape end
        if type(b.extendEye)       == "boolean" then Features.ExtendEye       = b.extendEye end
        if type(b.musketExtender)  == "boolean" then Features.MusketExtender  = b.musketExtender end
        if type(b.napeFollowRange) == "number"  then NapeFollowRange          = b.napeFollowRange end
        if type(b.noAttack)        == "boolean" then Features.NoAttack        = b.noAttack end
        if type(b.bladeDura)       == "boolean" then Features.BladeDura       = b.bladeDura end
