-- Walk roots and collect every ModuleScript under them.
FetchEnchants = function()
    local data = {}
    local seen = {}  -- de-dup by name (lowercase)

    -- 1. Populate from hardcoded database (source of truth)
    for rarity, list in pairs(TALENT_DB) do
        for _, talentName in ipairs(list) do
            local key = talentName:lower()
            if not seen[key] then
                seen[key] = true
                table.insert(data, {
                    name = talentName,
                    rarity = rarity,
                    path = "[TalentDB] " .. rarity,
                    owned = false,
                })
            end
        end
    end

    -- 2. Mark owned by scanning PlayerGui (requires profile menu OPEN)
    local pg = LocalPlayer:FindFirstChild("PlayerGui")
    if pg then
        local mm = pg:FindFirstChild("MainMenu")
        if mm then
            local scrollPath = "MenuFrame.Frames.Profile.Profile.Talents.ScrollingFrame"
            local node = mm
            for part in scrollPath:gmatch("[^%.]+") do
                if not node then break end
                node = node:FindFirstChild(part)
            end
            if node then
                for _, child in ipairs(node:GetChildren()) do
                    if child:IsA("GuiObject") and child.Name ~= "TalentTemplate" then
                        local key = child.Name:lower()
                        -- If owned but not in our DB, add it with Unknown rarity
                        local found = false
                        for _, entry in ipairs(data) do
                            if entry.name:lower() == key then
                                entry.owned = true
                                found = true
                                break
                            end
                        end
                        if not found then
                            seen[key] = true
                            table.insert(data, {
                                name = child.Name,
                                rarity = "Unknown",
                                path = child:GetFullName(),
                                owned = true,
                            })
                        end
                    end
                end
            end
        end
    end

    -- Sort: rarity-bucket order, owned first within bucket, then alpha
    local order = {}
    for i, k in ipairs(ENCHANT_RARITIES_ORDER) do order[k] = i end
    table.sort(data, function(a, b)
        local ra = order[a.rarity] or 99
        local rb = order[b.rarity] or 99
        if ra ~= rb then return ra < rb end
        if a.owned ~= b.owned then return a.owned end
        return a.name < b.name
    end)

    local ownedCount = 0
    for _, e in ipairs(data) do if e.owned then ownedCount = ownedCount + 1 end end
    GUI.EnchantsData   = data
    GUI.EnchantsStatus = string.format("%d total, %d owned", #data, ownedCount)
    print(string.format("[Enchants] %d entries (%d owned)", #data, ownedCount))
    do return end

    -- (Legacy code below — never reached, kept for reference)
    local rs = game:GetService("ReplicatedStorage")

    -- ReplicatedStorage roots. Walk EACH that exists.
    local rootPathStrs = {
        "Client.Progression.Enchantments.Enchantments",
        "Enchantments",
        "ReplicatedAssets.AllTalents",
        "ReplicatedAssets.AllTalents.TalentLibrary",
        "ReplicatedAssets.AllTalents.TalentLibrary.BaseTalents",
        "ReplicatedAssets.AllTalents.TalentLibrary.PathTalents",
        "ReplicatedAssets.AllTalents.TalentLibrary.UniqueTalents",
        "ReplicatedAssets.AllTalents.TalentLibrary.StaffTalents",
        "ReplicatedAssets.AllTalents.TraitLibrary",
        "ReplicatedAssets.AllTalents.SkillLibrary",
        "ReplicatedAssets.Library.Talents",
    }

    local function resolvePath(pathStr)
        local node = rs
        for part in pathStr:gmatch("[^%.]+") do
            if not node then return nil end
            local ok, child = pcall(function() return node:FindFirstChild(part) end)
            if not ok then return nil end
            node = child
        end
        return node
    end

    local rootsWalked = 0
    for _, p in ipairs(rootPathStrs) do
        local r = resolvePath(p)
        if r then
            rootsWalked = rootsWalked + 1
            for _, d in ipairs(r:GetDescendants()) do
                if d:IsA("ModuleScript") then
                    local full = d:GetFullName()
                    if not seen[full] then
                        seen[full] = true
                        table.insert(data, {
                            name = d.Name,
                            rarity = enchantRarityFromAncestors(d),
                            path = full,
                        })
                    end
                end
            end
        end
    end

    -- AoT Ugc: PlayerGui owned-talents list. Frame children of the Talents
    -- ScrollingFrame are named after each owned talent (e.g. "The 45th Class",
    -- "Path of The Savior"). Skip Traits/Burns/Skills — those aren't talents.
    -- Try to infer rarity from the Frame's template attribute or ancestor card type.
    local function inferTalentRarity(frame)
        -- 1. Direct attribute
        local rarAttr
        pcall(function() rarAttr = frame:GetAttribute("Rarity") end)
        if rarAttr and ENCHANT_RARITY_COLORS[rarAttr] then return rarAttr end
        -- 2. Look for a *Card descendant template (BaseCard/RareCard/etc.)
        for _, c in ipairs(frame:GetDescendants()) do
            local cn = c.Name
            if cn:find("Card") then
                local b = bucketFromFolderName(cn)
                if b ~= "Unknown" then return b end
            end
        end
        -- 3. Frame name keyword
        return bucketFromFolderName(frame.Name)
    end

    local pg = LocalPlayer:FindFirstChild("PlayerGui")
    if pg then
        local scrollPath = "MainMenu.MenuFrame.Frames.Profile.Profile.Talents.ScrollingFrame"
        local node = pg
        for part in scrollPath:gmatch("[^%.]+") do
            if not node then break end
            node = node:FindFirstChild(part)
        end
        if node then
            for _, child in ipairs(node:GetChildren()) do
                -- Skip generic templates / non-talent UI helpers
                if child.Name ~= "TalentTemplate" and child.Name ~= "ItemTemplate"
                   and child:IsA("GuiObject") then
                    local full = child:GetFullName()
                    if not seen[full] then
                        seen[full] = true
                        table.insert(data, {
                            name   = child.Name,
                            rarity = inferTalentRarity(child),
                            path   = full,
                            owned  = true,
                        })
                    end
                end
            end
        end
    end

    -- Final fallback: keyword scan if NOTHING found
    if #data == 0 then
        for _, d in ipairs(rs:GetDescendants()) do
            if d:IsA("ModuleScript") then
                local n = d.Name:lower()
                if n:find("enchant") or n:find("talent") or n:find("trait") then
                    local full = d:GetFullName()
                    if not seen[full] then
                        seen[full] = true
                        table.insert(data, {
                            name = d.Name,
                            rarity = enchantRarityFromAncestors(d),
                            path = full,
                        })
                    end
                end
            end
        end
    end

    -- Sort: rarity-bucket order, then alpha
    local order = {}
    for i, k in ipairs(ENCHANT_RARITIES_ORDER) do order[k] = i end
    table.sort(data, function(a, b)
        local ra = order[a.rarity] or 99
        local rb = order[b.rarity] or 99
        if ra ~= rb then return ra < rb end
        return a.name < b.name
    end)

    GUI.EnchantsData   = data
    GUI.EnchantsStatus = string.format("%d entries (%d roots)", #data, rootsWalked)
    print(string.format("[Enchants] %d entries from %d roots", #data, rootsWalked))
end

-- Filtered view based on rarity sub-tab. "All" hides Unknown entries.
local function buildFilteredEnchantList()
    local all = GUI.EnchantsData or {}
    local filter = GUI.EnchantsRarityFilter
    local out = {}
    for _, e in ipairs(all) do
        if filter == "All" then
            if e.rarity ~= "Unknown" then table.insert(out, e) end
        elseif e.rarity == filter then
            table.insert(out, e)
        end
    end
    return out
end

-- Which rarity buckets are actually present in current data (for sub-tabs).
-- Skip "Unknown" — clutter.
local function presentRarities()
    local present = {}
    local list = { "All" }
    if GUI.EnchantsData then
        for _, e in ipairs(GUI.EnchantsData) do
            if e.rarity ~= "Unknown" then
                present[e.rarity] = true
            end
        end
    end
    for _, r in ipairs(ENCHANT_RARITIES_ORDER) do
        if r ~= "Unknown" and present[r] then table.insert(list, r) end
    end
    return list
end

