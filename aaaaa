local function IsInside(mx, my, x, y, w, h)
    return mx >= x and mx <= x + w and my >= y and my <= y + h
end
local function clamp01(v) return v < 0 and 0 or (v > 1 and 1 or v) end
local function lighten(c, amt)
    return Color3.new(clamp01(c.R+amt), clamp01(c.G+amt), clamp01(c.B+amt))
end
local function lerpColor(a, b, t)
    return Color3.new(a.R+(b.R-a.R)*t, a.G+(b.G-a.G)*t, a.B+(b.B-a.B)*t)
end
local function pressEffect(el, base)
    task.spawn(function()
        pcall(function() el.Color = lighten(base, 0.28) end)
        task.wait(0.09)
        pcall(function() el.Color = base end)
    end)
end
local function newAnimToken() GUI.AnimToken = GUI.AnimToken + 1; return GUI.AnimToken end
local function isAnimCurrent(t) return t == GUI.AnimToken end
local function toast(msg) pcall(function() notify(msg, "Verfall", 2) end) end

