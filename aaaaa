local function PageSettings()
    local zb = 13
    local baseY = contentTop()
    local fullW = Config.WinW - Config.ContentPad * 2
    local cardW = math.floor(fullW * 0.55)
    local cardX = Config.WinX + Config.ContentPad + math.floor((fullW - cardW) / 2)
    local lx = cardX + Config.CardPad
    local rightEdge = cardX + cardW - Config.CardPad
    local controlsH = 52 + 2 * Config.RowHeight + 14
    local cY = DrawCard(cardX, baseY, cardW, controlsH, "Controls", zb)

    DrawKeyBindRow(lx, rightEdge, cY, "Toggle Key", GUI.ListeningForKey, GUI.ToggleKey, zb, "Settings", function() GUI.ListeningForKey = true end)
    DrawKeyBindRow(lx, rightEdge, cY + Config.RowHeight, "Close Key", GUI.ListeningForCloseKey, GUI.CloseKey, zb, "Settings", function() GUI.ListeningForCloseKey = true end)

    local cfgY = baseY + controlsH + 14
    local cfgH = 52 + 2 * Config.RowHeight + 14
    local cfgCY = DrawCard(cardX, cfgY, cardW, cfgH, "Config", zb)
    local bW, bH, gap = 110, 26, 14
    local rowX = cardX + math.floor((cardW - (bW * 2 + gap)) / 2)
    DrawTextButton(rowX, cfgCY + 5, bW, bH, "Save Config", Color3.fromRGB(220,220,225), Color3.fromRGB(40,80,50), zb, function()
        saveConfig(); toast("Config saved")
    end)
    DrawTextButton(rowX + bW + gap, cfgCY + 5, bW, bH, "Load Config", Color3.fromRGB(220,220,225), Color3.fromRGB(60,40,80), zb, function()
        loadConfig(); CreateContent("Settings"); toast("Config loaded")
    end)
    DrawTextButton(rowX, cfgCY + 5 + Config.RowHeight, bW * 2 + gap, bH, "Reset to Defaults", Color3.fromRGB(255,220,220), Color3.fromRGB(60,30,30), zb, function()
        resetConfig(); CreateContent("Settings"); toast("Config reset")
    end)
end

