-- ESP rendering runs on RenderStepped so it's in sync with the camera —
-- no one-frame delay when you move the camera fast. Scan runs separately
-- on a 0.5s timer (cheap, doesn't need per-frame).
local _espScanTimer = 0
-- ============================================================
-- TITAN ESP (box + HP bar/number + nape marker) — own object pool
-- ============================================================
local TITAN_ESP = {
    Objects     = {},
    Color       = Color3.fromRGB(255, 120, 40),  -- orange box/label
    NapeColor   = Color3.fromRGB(255, 60, 60),    -- bright red nape ring
    MaxDistance = 100000,
}
local function makeTitanObj(model)
    local box = Drawing.new("Square")
    box.Thickness = 1; box.Filled = false; box.Color = TITAN_ESP.Color
    box.Visible = false; box.ZIndex = 2
    local name = Drawing.new("Text")
    name.Size = 13; name.Center = true; name.Outline = true; name.Font = Drawing.Fonts.System
    name.Color = TITAN_ESP.Color; name.Visible = false; name.ZIndex = 3
    local hpFill = Drawing.new("Square")
    hpFill.Filled = true; hpFill.Color = Color3.fromRGB(60, 220, 80)
    hpFill.Visible = false; hpFill.ZIndex = 2
    local hpNum = Drawing.new("Text")
    hpNum.Size = 12; hpNum.Center = true; hpNum.Outline = true; hpNum.Font = Drawing.Fonts.System
    hpNum.Color = Color3.fromRGB(60, 220, 80); hpNum.Visible = false; hpNum.ZIndex = 3
    local nape = Drawing.new("Circle")
    nape.Thickness = 2; nape.Filled = false; nape.NumSides = 14; nape.Radius = 5
    nape.Color = TITAN_ESP.NapeColor; nape.Visible = false; nape.ZIndex = 3
    return { model = model, hrp = nil, hum = nil,
             box = box, name = name, hpFill = hpFill, hpNum = hpNum, nape = nape, cache = {} }
end
local function hideTitanObj(o)
    if o.cache.hidden then return end
    o.cache.hidden = true
    pcall(function()
        o.box.Visible = false; o.name.Visible = false
        o.hpFill.Visible = false; o.hpNum.Visible = false; o.nape.Visible = false
    end)
    o.cache.boxVis, o.cache.nameVis, o.cache.hpFillVis, o.cache.hpNumVis, o.cache.napeVis = false, false, false, false, false
end
local function removeTitanObj(o)
    pcall(function() o.box:Remove() end);    pcall(function() o.name:Remove() end)
    pcall(function() o.hpFill:Remove() end); pcall(function() o.hpNum:Remove() end)
    pcall(function() o.nape:Remove() end)
end
local function titanScan()
    local world = Workspace:FindFirstChild("World")
    local titans = world and world:FindFirstChild("Titans")
    if not titans then
        for k, o in pairs(TITAN_ESP.Objects) do removeTitanObj(o); TITAN_ESP.Objects[k] = nil end
        return
    end
    local present = {}
    for _, model in ipairs(titans:GetChildren()) do
        if model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart then
            present[model] = true
            if not TITAN_ESP.Objects[model] then TITAN_ESP.Objects[model] = makeTitanObj(model) end
        end
    end
    for k, o in pairs(TITAN_ESP.Objects) do
        if not present[k] then removeTitanObj(o); TITAN_ESP.Objects[k] = nil end
    end
end
local function titanEspUpdate()
    if not Features.TitanESP then
        for _, o in pairs(TITAN_ESP.Objects) do hideTitanObj(o) end
        return
    end
    local myPos = localRootPos()
    for model, o in pairs(TITAN_ESP.Objects) do
        if not model or not model.Parent then
            hideTitanObj(o)
        else
            -- Box + name first, in their OWN pcall. HP/nape reads go in SEPARATE pcalls
            -- below so if a titan-Humanoid read throws it can't hide the box (that was the
            -- bug — one error hid everything). Direct .Visible like the working standalone.
            local shown = false
            pcall(function()
                local hrp = o.hrp
                if not hrp or not hrp.Parent then
                    hrp = model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart
                    o.hrp = hrp
                end
                local pos = hrp and hrp.Position or nil
                if not pos then return end
                local d = myPos and (pos - myPos).Magnitude or nil
                if d and d > TITAN_ESP.MaxDistance then return end
                local headS, onHead = WorldToScreen(pos + Vector3.new(0, 9, 0))
                local footS, onFoot = WorldToScreen(pos - Vector3.new(0, 9, 0))
                if not (headS and footS) or (not onHead and not onFoot) then return end
                local topY = headS.Y
                local boxH = footS.Y - topY
                local boxW = boxH * 0.5
                local centerX = (headS.X + footS.X) / 2
                o.box.Position = Vector2.new(centerX - boxW / 2, topY)
                o.box.Size = Vector2.new(boxW, boxH)
                o.box.Visible = true
                o.name.Position = Vector2.new(centerX, topY - 16)
                o.name.Text = "Titan" .. (d and ("  " .. math.floor(d + 0.5) .. "m") or "")
                o.name.Visible = true
                -- stash geometry for the HP/nape passes
                o._cx, o._topY, o._boxH, o._boxX, o._footY, o._d, o._pos = centerX, topY, boxH, centerX - boxW / 2, footS.Y, d, pos
                o.cache.hidden = nil
                shown = true
            end)
            if not shown then
                hideTitanObj(o)
            else
                -- NAPE HEALTH (the real titan HP — what kills it). Humanoid.Health is
                -- 100/inf and useless; NapeHealth is an attribute on the titan model.
                -- Track the max we've seen per titan for the bar fill.
                pcall(function()
                    local nape = model:GetAttribute("NapeHealth")
                    if nape and o._boxH > 4 then
                        o.maxNape = math.max(o.maxNape or nape, nape)
                        local pct = (o.maxNape > 0) and math.max(0, math.min(1, nape / o.maxNape)) or 0
                        local barW = 3
                        local fillH = o._boxH * pct
                        o.hpFill.Position = Vector2.new(o._boxX - barW - 3, o._topY + (o._boxH - fillH))
                        o.hpFill.Size = Vector2.new(barW, fillH)
                        o.hpFill.Color = Color3.fromRGB(math.floor(255 * (1 - pct)), math.floor(220 * pct), 60)
                        o.hpFill.Visible = true
                        o.hpNum.Position = Vector2.new(o._cx, o._footY + 1)
                        o.hpNum.Text = "Nape " .. math.floor(nape)
                        o.hpNum.Color = o.hpFill.Color
                        o.hpNum.Visible = true
                    else
                        o.hpFill.Visible = false; o.hpNum.Visible = false
                    end
                end)
                -- Nape marker (separate pcall)
                pcall(function()
                    if Features.TitanNapeMarker then
                        local napePos
                        if not Features.NapeFollow then
                            local dp = model:FindFirstChild("DamagePoints")
                            local np = dp and dp:FindFirstChild("Nape")
                            if np then napePos = np.Position end
                        end
                        if not napePos then
                            local head = model:FindFirstChild("Head")
                            napePos = head and head.Position or (o._pos + Vector3.new(0, 5, 0))
                        end
                        local ns, onN = WorldToScreen(napePos)
                        if ns and onN then
                            o.nape.Position = Vector2.new(ns.X, ns.Y)
                            o.nape.Radius = o._d and math.max(3, math.min(11, 700 / math.max(1, o._d))) or 6
                            o.nape.Visible = true
                        else o.nape.Visible = false end
                    else o.nape.Visible = false end
                end)
            end
        end
    end
end

