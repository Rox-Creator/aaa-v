        ul.Color = Colors.AccentRed; ul.Thickness = 1; ul.Visible = true; ul.ZIndex = zb + 3
        table.insert(GUI.ContentElements, ul)
    end
    return y + 52
end

-- Slide the knob + cross-fade the track when a toggle flips. Non-blocking,
-- pcall-guarded so a rebuild mid-slide can't error.
local function animateToggle(knob, bg, fromX, toX, knobY, newOn)
    local fromC = newOn and Colors.ToggleOff or Colors.ToggleOn
    local toC   = newOn and Colors.ToggleOn or Colors.ToggleOff
    task.spawn(function()
        for s = 1, 6 do
            local et = 1 - (1 - s / 6) ^ 3
            pcall(function() knob.Position = Vector2.new(fromX + (toX - fromX) * et, knobY) end)
            pcall(function() bg.Color = lerpColor(fromC, toC, et) end)
            task.wait(0.012)
        end
    end)
end

-- Animated toggle row. onFlip() just flips the underlying flag (NO rebuild) —
-- none of our toggles change page layout, so we animate in place instead.
local function DrawCardToggleRow(cardX, cardW, curY, label, isOn, zb, onFlip)
    local lx = cardX + Config.CardPad
    local rightEdge = cardX + cardW - Config.CardPad

    local lbl = Drawing.new("Text")
    lbl.Position = Vector2.new(lx, curY + 2); lbl.Text = label
    lbl.Color = Colors.TextPrimary; lbl.Size = 14; lbl.Font = Drawing.Fonts.System
    lbl.Center = false; lbl.Outline = false; lbl.Visible = true; lbl.ZIndex = zb + 5
    table.insert(GUI.ContentElements, lbl)

    local tw, th = Config.ToggleW, Config.ToggleH
    local toggleX = rightEdge - tw
    local offX = toggleX + 2
    local onX  = toggleX + tw - th + 2
    local knobC = (th - 4) / 2
    local knobY = curY + 1 + th / 2

    local bg = Drawing.new("Square")
    bg.Position = Vector2.new(toggleX, curY + 1); bg.Size = Vector2.new(tw, th)
    bg.Color = isOn and Colors.ToggleOn or Colors.ToggleOff
    bg.Filled = true; bg.Corner = 8; bg.Visible = true; bg.ZIndex = zb + 3
    table.insert(GUI.ContentElements, bg)

    local knob = Drawing.new("Circle")
    knob.Position = Vector2.new((isOn and onX or offX) + knobC, knobY); knob.Radius = knobC
    knob.Color = Color3.fromRGB(230, 230, 235); knob.Filled = true
    knob.NumSides = 16; knob.Visible = true; knob.ZIndex = zb + 4
    table.insert(GUI.ContentElements, knob)

    local state = isOn
    local hoverInfo = { el = bg, base = isOn and Colors.ToggleOn or Colors.ToggleOff }
    table.insert(GUI.Clickables, {
        x = toggleX - 20, y = curY, w = tw + 20, h = th + 4,
        onClick = function()
            onFlip()
            local oldOn = state
            local newOn = not oldOn
            state = newOn
            hoverInfo.base = newOn and Colors.ToggleOn or Colors.ToggleOff
            animateToggle(knob, bg, (oldOn and onX or offX) + knobC, (newOn and onX or offX) + knobC, knobY, newOn)
        end,
        hover = hoverInfo,
    })
    return curY + Config.RowHeight
end

local function DrawSlider(px, py, value, minV, maxV, width, zb)
    local frac = clamp01((value - minV) / (maxV - minV))
    local fillW = math.max(2, frac * width)

    local track = Drawing.new("Square")
    track.Position = Vector2.new(px, py); track.Size = Vector2.new(width, Config.SliderH)
    track.Color = Colors.ToggleOff; track.Filled = true; track.Corner = 4
    track.Visible = true; track.ZIndex = zb
    table.insert(GUI.ContentElements, track)

    local fill = Drawing.new("Square")
    fill.Position = Vector2.new(px, py); fill.Size = Vector2.new(fillW, Config.SliderH)
    fill.Color = Colors.SliderFill; fill.Filled = true; fill.Corner = 4
    fill.Visible = true; fill.ZIndex = zb + 1
    table.insert(GUI.ContentElements, fill)

    local knob = Drawing.new("Circle")
    knob.Position = Vector2.new(px + fillW, py + Config.SliderH / 2); knob.Radius = 5
    knob.Color = Color3.fromRGB(200, 210, 240); knob.Filled = true
    knob.NumSides = 16; knob.Visible = true; knob.ZIndex = zb + 2
    table.insert(GUI.ContentElements, knob)

    return fill, knob
end

-- Slider row that updates in-place during drag (NO full rebuild) for smoothness.
-- onChange(val) writes the value; onLive() optionally refreshes derived visuals.
local function DrawCardSliderRow(cardX, cardW, curY, label, value, minV, maxV, zb, onChange, onLive, valSize, valDX, valDY)
    local lx = cardX + Config.CardPad
    local rightEdge = cardX + cardW - Config.CardPad

    local lbl = Drawing.new("Text")
    lbl.Position = Vector2.new(lx, curY); lbl.Text = label
    lbl.Color = Colors.TextPrimary; lbl.Size = 13; lbl.Font = Drawing.Fonts.System
    lbl.Center = false; lbl.Outline = false; lbl.Visible = true; lbl.ZIndex = zb + 5
    table.insert(GUI.ContentElements, lbl)

    -- Centered near the right edge so wide values (e.g. 100000) never overflow.
    local valText = Drawing.new("Text")
    valText.Position = Vector2.new(rightEdge - 28 + (valDX or 0), curY + (valDY or 0)); valText.Text = tostring(math.floor(value))
    valText.Color = Colors.Accent; valText.Size = valSize or 13; valText.Font = Drawing.Fonts.System
    valText.Center = true; valText.Outline = false; valText.Visible = true; valText.ZIndex = zb + 5
    table.insert(GUI.ContentElements, valText)

    local sliderX = lx
    local sliderW = cardW - Config.CardPad * 2
    local sy = curY + 20
    local fill, knob = DrawSlider(sliderX, sy, value, minV, maxV, sliderW, zb + 3)

    table.insert(GUI.Clickables, {
        x = sliderX - 6, y = sy - 8, w = sliderW + 12, h = Config.SliderH + 16,
        isSlider = true,
        onClick = function(mx)
            local frac = clamp01((mx - sliderX) / sliderW)
            local val = math.floor(minV + frac * (maxV - minV) + 0.5)
            onChange(val)
            local fr = clamp01((val - minV) / (maxV - minV))
            pcall(function() fill.Size = Vector2.new(math.max(2, fr * sliderW), Config.SliderH) end)
            pcall(function() knob.Position = Vector2.new(sliderX + fr * sliderW, sy + Config.SliderH / 2) end)
            pcall(function() valText.Text = tostring(val) end)
            if onLive then pcall(onLive) end
        end,
    })
    return curY + SLIDER_ROW_H
end

