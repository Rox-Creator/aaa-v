    local elemText = Drawing.new("Text")
    elemText.Position = Vector2.new(Config.WinX + halfW * 0.5, barY + 14); elemText.Text = "Elements"
    elemText.Color = GUI.SubTab == "Elements" and Colors.TextPrimary or Colors.TextMuted
    elemText.Size = 16; elemText.Font = GUI.SubTab == "Elements" and Drawing.Fonts.SystemBold or Drawing.Fonts.System
    elemText.Center = true; elemText.Outline = false; elemText.Visible = true; elemText.ZIndex = zb + 1
    table.insert(GUI.SubTabElements, elemText)

    local styleText = Drawing.new("Text")
    styleText.Position = Vector2.new(Config.WinX + halfW + halfW * 0.5, barY + 14); styleText.Text = "Style"
    styleText.Color = GUI.SubTab == "Style" and Colors.TextPrimary or Colors.TextMuted
    styleText.Size = 16; styleText.Font = GUI.SubTab == "Style" and Drawing.Fonts.SystemBold or Drawing.Fonts.System
    styleText.Center = true; styleText.Outline = false; styleText.Visible = true; styleText.ZIndex = zb + 1
    table.insert(GUI.SubTabElements, styleText)

    local underX = (GUI.SubTab == "Style") and (Config.WinX + halfW) or Config.WinX
    local under = Drawing.new("Line")
    under.From = Vector2.new(underX + 1, barY + Config.SubTabH - 2)
    under.To   = Vector2.new(underX + halfW - 1, barY + Config.SubTabH - 2)
    under.Color = Colors.AccentRed; under.Thickness = 2; under.Visible = true; under.ZIndex = zb + 2
    table.insert(GUI.SubTabElements, under)
    GUI.SubTabUnderline = under

    -- Slide the glow + underline from the old half to the new one, then rebuild
    -- content — same feel as Menu.lua's animateSubTabSwitch.
    local function animateSubTabSwitch(newName)
        if GUI.SubTab == newName then return end
        local fromX = (GUI.SubTab == "Style") and (Config.WinX + halfW) or Config.WinX
        local toX   = (newName == "Style") and (Config.WinX + halfW) or Config.WinX
        local lineY = barY + Config.SubTabH - 2
        GUI.SubTab = newName
        local g, u = GUI.SubTabGlow, GUI.SubTabUnderline
        local token = newAnimToken()
        task.spawn(function()
            for s = 1, 10 do
                if not isAnimCurrent(token) then return end
                local et = 1 - (1 - s / 10) ^ 3
                local zx = fromX + (toX - fromX) * et
                if g then pcall(function() g.Position = Vector2.new(zx, barY) end) end
                if u then pcall(function()
                    u.From = Vector2.new(zx + 1, lineY)
                    u.To   = Vector2.new(zx + halfW - 1, lineY)
                end) end
                task.wait(0.016)
            end
            if GUI.SelectedPage == "Main" then CreateContent("Main") end
        end)
    end

    table.insert(GUI.SubTabClickables, { x = Config.WinX, y = barY, w = halfW, h = Config.SubTabH,
        onClick = function() animateSubTabSwitch("Elements") end })
    table.insert(GUI.SubTabClickables, { x = Config.WinX + halfW, y = barY, w = halfW, h = Config.SubTabH,
        onClick = function() animateSubTabSwitch("Style") end })
end

