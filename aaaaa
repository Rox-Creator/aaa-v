    ["replicatedstorage.replicatedassets.sfx"]        = true,
    ["replicatedstorage.replicatedassets.models"]     = true,
}

-- Classes the diff treats as LEAF — node recorded but not walked.
local RS_LEAF_CLASSES = {
    ParticleEmitter = true, Beam = true, Trail = true, Smoke = true, Fire = true,
    Sparkles = true, PointLight = true, SpotLight = true, SurfaceLight = true,
    Attachment = true, Sound = true, Animation = true, Sky = true, Clouds = true,
    ColorCorrectionEffect = true, BloomEffect = true, BlurEffect = true,
    DepthOfFieldEffect = true, SunRaysEffect = true, Decal = true, Texture = true,
    SpecialMesh = true, BlockMesh = true, CylinderMesh = true, FileMesh = true,
    SurfaceAppearance = true,
}

-- Classes completely skipped — engine plumbing noise.
local RS_SKIP_CLASSES = {
    Atmosphere = true,
    Motor6D = true, Motor = true, Weld = true, ManualWeld = true,
    WeldConstraint = true, Snap = true, Glue = true,
    Rotate = true, RotateV = true, RotateP = true,
    HingeConstraint = true, BallSocketConstraint = true, RodConstraint = true,
    RopeConstraint = true, SpringConstraint = true, SlidingBallConstraint = true,
    CylindricalConstraint = true, PrismaticConstraint = true, UniversalConstraint = true,
    LineForce = true, Torque = true, VectorForce = true,
    AlignOrientation = true, AlignPosition = true, AngularVelocity = true,
    LinearVelocity = true, PlaneConstraint = true, NoCollisionConstraint = true,
    KeyframeSequence = true, Keyframe = true, KeyframeMarker = true,
    Pose = true, NumberPose = true, AnimationConstraint = true,
    BoneAttachment = true, Bone = true,
