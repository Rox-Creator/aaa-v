animateMainTabUnderline = function(toBtn)
    local under = GUI.MainTabUnderline
    if not (under and toBtn) then return end
    local fromL, fromR, fromY
    pcall(function() fromL = under.From.X end)
    pcall(function() fromR = under.To.X end)
    pcall(function() fromY = under.From.Y end)
    local toL, toR = navUnderlineBounds(toBtn)
    local lineY = fromY or (toBtn.Y + Config.HeaderH - 2)
    fromL = fromL or toL; fromR = fromR or toR
