    [0x2D]="Insert",[0x2E]="Delete",[0x24]="Home",[0x23]="End",[0x21]="PgUp",[0x22]="PgDn",
    [0x60]="Num0",[0x61]="Num1",[0x62]="Num2",[0x63]="Num3",[0x64]="Num4",[0x65]="Num5",
    [0x66]="Num6",[0x67]="Num7",[0x68]="Num8",[0x69]="Num9",
}
for i = 0x41, 0x5A do VK_NAMES[i] = string.char(i) end
