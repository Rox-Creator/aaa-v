applyNapeFollow = function()
    restoreNapeFollow()
    local swingUntil = 0
    local napeIdleAccum = 0
    Pins.NapeFollow = RunService.Heartbeat:Connect(function(dt)
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local myPos = hrp.Position

        -- The cube is full-size ONLY during a swing window; the rest of the time it's tiny
        -- so your horse rides straight through it. We open the window on EITHER the M1 click
        -- (fires first, gives the cube a head start so hits don't whiff) OR IsSwinging, and
        -- hold it 0.4s to comfortably cover the hit frame.
        local active = false
        local menuOpen = false
        pcall(function() menuOpen = (LibWindow and LibWindow:IsOpen()) and true or false end)
        pcall(function() if char:GetAttribute("IsSwinging") then active = true end end)
        -- Don't treat M1 as a swing while the menu is OPEN: clicking/dragging the menu holds M1,
        -- which would force the heavy titan scan on every frame — the real cause of the menu lag.
        -- (Menu closed = normal play, M1 still gives the swing a head start.)
        pcall(function() if (not menuOpen) and ismouse1pressed() then active = true end end)
        if active then swingUntil = os.clock() + 0.4 end
        local touchable = os.clock() < swingUntil
        -- falling edge of the swing → restore shrunken limbs once
        local justEnded = (not touchable) and Pins._wasNapeTouchable
        Pins._wasNapeTouchable = touchable

        -- PERF: per-frame titan scans + Size writes are the UI-lag culprit. They only matter
        -- while a swing is live (touchable) or on its falling edge (justEnded restores there).
        -- When idle (just riding around), drop to ~5Hz maintenance so the menu and game stay
        -- smooth. Swing frames run at full speed below, so hits land exactly as before.
        if (not touchable) and (not justEnded) then
            napeIdleAccum = napeIdleAccum + (dt or 0.016)
            if napeIdleAccum < 0.2 then return end
            napeIdleAccum = 0
        else
            napeIdleAccum = 0
        end

        local world = Workspace:FindFirstChild("World")
        if not world then return end
        local titans = world:FindFirstChild("Titans")
        if not titans then return end

        -- Restore any limbs we shrank, the instant the swing ends.
        if justEnded then
            for part, sz in pairs(Pins.LimbOriginals) do
                pcall(function() part.Size = sz end)
            end
            Pins.LimbOriginals = {}
        end

        local range = NapeFollowRange
        -- Reverted to the pre-lag-fix version (no throttle, no size cap) — the big cube
        -- + every-frame tracking is what actually landed hits reliably.
        local size  = math.max(20, range / 2)
        local clamp = math.max(15, range * 0.45)

        for _, titan in ipairs(titans:GetChildren()) do
            local titanHrp = titan:FindFirstChild("HumanoidRootPart")
            if titanHrp then
                local dist = (titanHrp.Position - myPos).Magnitude
                if dist <= range then
                    local dp = titan:FindFirstChild("DamagePoints")
                    if dp then
                        -- Which weakpoints to extend (user-toggleable: Nape and/or Eye)
                        local parts = {}
                        if Features.ExtendNape then parts[#parts + 1] = "Nape" end
                        if Features.ExtendEye  then parts[#parts + 1] = "Eye"  end
                        for _, name in ipairs(parts) do
                            local p = dp:FindFirstChild(name)
                            if p and p:IsA("BasePart") then
                                -- Snapshot the real size ONCE (before we ever resize it) so we
                                -- can restore it when the extender is toggled off.
                                if not Pins.NapeOriginals[p] then
                                    local ok, sz = pcall(function() return p.Size end)
                                    if ok and sz then Pins.NapeOriginals[p] = sz end
                                end
                                if touchable then
                                    -- SWINGING: blow it up to a big cube at you so the hit lands.
                                    -- CanQuery=TRUE here so the nape intercepts the swing's
                                    -- raycast — otherwise the ray passes through and the LEG
                                    -- behind it steals the hit. (Only true during the swing
                                    -- window, so the horse — which only rides through while the
                                    -- cube is tiny — is unaffected.)
                                    local delta = myPos - titanHrp.Position
                                    if delta.Magnitude > clamp then
                                        delta = delta.Unit * clamp
                                    end
                                    local target = titanHrp.Position + delta
                                    pcall(function() p.Anchored = true end)
                                    pcall(function() p.CanCollide = false end)
                                    pcall(function() p.CanQuery = true end)
                                    pcall(function() p.CanTouch = true end)
                                    pcall(function() p.Massless = true end)
                                    pcall(function() p.AssemblyLinearVelocity = Vector3.new(0, 0, 0) end)
                                    pcall(function() p.Size = Vector3.new(size, size, size) end)
                                    pcall(function() p.CFrame = CFrame.new(target) end)  -- atomic vs Position
                                    pcall(function() p.Transparency = 1 end)
                                    pcall(function() p.LocalTransparencyModifier = 1 end)
                                    for _, joint in ipairs(p:GetChildren()) do
                                        if joint:IsA("WeldConstraint") or joint:IsA("Weld") or joint:IsA("Motor6D") then
                                            pcall(function() joint.Enabled = false end)
                                        end
                                    end
                                else
                                    -- NOT swinging: keep it TINY so there's no big part in your
                                    -- horse's path (a huge cube stops the horse regardless of the
                                    -- collide/query/touch flags). It only needs to be big for the
                                    -- instant you swing.
                                    pcall(function() p.CanCollide = false end)
                                    pcall(function() p.CanTouch = false end)
                                    pcall(function() p.Size = Vector3.new(0.5, 0.5, 0.5) end)
                                end
                            end
                        end
                        -- "ALWAYS NAPE": during the swing, make every OTHER hittable part
                        -- (legs/arms/torso meshes + any non-extended damage point) un-hittable
                        -- so the blade can only land on the nape. Restored when not swinging.
                        -- The leg meshes are DIRECT children of the titan; DamagePoints.Nape/Eye
                        -- live in the folder. One pcall per titan keeps the GC cost down.
                        -- "ALWAYS NAPE": during the swing, SHRINK the titan's limb meshes to
                        -- nothing so the blade can't land on a leg/arm. Size writes work in
                        -- Matcha (CanTouch/CanQuery don't — they read nil) — this is the same
                        -- trick the Musket Extender uses to kill the eye. Snapshot each limb's
                        -- real size once; restored on the swing's falling edge + on toggle-off.
                        if touchable then
                            pcall(function()
                                for _, c in ipairs(titan:GetDescendants()) do
                                    if c:IsA("BasePart") then
                                        local nm = c.Name
                                        if nm:find("Leg") or nm:find("Arm") or nm:find("Foot") or nm:find("Hand") then
                                            if not Pins.LimbOriginals[c] then Pins.LimbOriginals[c] = c.Size end
                                            c.Size = Vector3.new(0.05, 0.05, 0.05)
                                        end
                                    end
                                end
                            end)
                        end
                    end
                end
            end
        end
    end)
end

-- Musket Extender: ranged nape for guns/crossbows. The gun raycasts from the barrel
-- and hits the FIRST queryable part. We KILL the Eye (so it can't steal the hit) and
-- make the Nape a big cube centered on the titan body so any shot at the titan lands
-- on the nape. Confirmed working with muskets 2026-06-22.
local MUSKET_NAPE_SIZE = 80
restoreMusketExtender = function()
    if Pins.MusketExtender then Pins.MusketExtender:Disconnect(); Pins.MusketExtender = nil end
end
applyMusketExtender = function()
    restoreMusketExtender()
    local musketAccum = 0
    Pins.MusketExtender = RunService.Heartbeat:Connect(function(dt)
        -- Throttle to ~25Hz (same reasoning as Hitbox Extender — per-frame is FPS death).
        musketAccum = musketAccum + (dt or 0.016)
        if musketAccum < 0.04 then return end
        musketAccum = 0
        local world = Workspace:FindFirstChild("World")
        if not world then return end
        local titans = world:FindFirstChild("Titans")
        if not titans then return end
        for _, titan in ipairs(titans:GetChildren()) do
            local dp  = titan:FindFirstChild("DamagePoints")
            local hrp = titan:FindFirstChild("HumanoidRootPart")
            if dp and hrp then
                -- Kill the eye so it can't steal the ranged hit
                local eye = dp:FindFirstChild("Eye")
                if eye and eye:IsA("BasePart") then
                    pcall(function() eye.Size = Vector3.new(0.05, 0.05, 0.05) end)
                    pcall(function() eye.CanQuery = false end)
                    pcall(function() eye.CanTouch = false end)
                end
                -- Nape = big cube enveloping titan center; the only ray-hittable target
                local nape = dp:FindFirstChild("Nape")
                if nape and nape:IsA("BasePart") then
                    pcall(function() nape.Anchored = true end)
                    pcall(function() nape.CanCollide = false end)
                    pcall(function() nape.CanTouch = true end)
                    pcall(function() nape.CanQuery = true end)   -- gun raycast can hit it
                    pcall(function() nape.Massless = true end)
                    pcall(function() nape.Size = Vector3.new(MUSKET_NAPE_SIZE, MUSKET_NAPE_SIZE, MUSKET_NAPE_SIZE) end)
                    pcall(function() nape.CFrame = CFrame.new(hrp.Position) end)
                    pcall(function() nape.Transparency = 1 end)
                    pcall(function() nape.LocalTransparencyModifier = 1 end)
                end
            end
        end
    end)
end

