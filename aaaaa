-- FEATURE: HORSE BOOST (snapshot originals, restore on disable)
-- ============================================================

local function findHorse()
    local world  = Workspace:FindFirstChild("World")
    local horses = world and world:FindFirstChild("Horses")
    return horses and horses:FindFirstChild(LocalPlayer.Name .. "_Horse")
end

local function num(v, d) return (type(v) == "number") and v or d end

function restoreHorse()
    if not Horse.SnapTaken then return end
    local h = findHorse()
    if h then
        pcall(function() h:SetAttribute("MaxStamina", Horse.Orig.MaxStamina) end)
        pcall(function() h:SetAttribute("RegenRate",  Horse.Orig.RegenRate) end)
        pcall(function() h:SetAttribute("MaxSpeed",   Horse.Orig.MaxSpeed) end)
    end
    Horse.SnapTaken = false
    Horse.Orig = {}
end

-- Stock horse values written by the boost (the game's old defaults).
local HORSE_MAX_STAMINA = 600
local HORSE_REGEN       = 50

-- Applied once on toggle-on and once whenever Max Speed changes — NOT looped.
applyHorseBoost = function()
    if not Features.HorseBoost then return end
    local h = findHorse()
    if not h then return end
    if not Horse.SnapTaken then
        -- Capture originals once. GetAttribute can return nil on Workspace
        -- models (Matcha) — fall back to the game's known stock values so a
        -- later restore still sets something sane.
        Horse.Orig = {
            MaxStamina = num(h:GetAttribute("MaxStamina"), 600),
            RegenRate  = num(h:GetAttribute("RegenRate"), 50),
            MaxSpeed   = num(h:GetAttribute("MaxSpeed"), 65),
        }
        Horse.SnapTaken = true
    end
    pcall(function() h:SetAttribute("MaxStamina", HORSE_MAX_STAMINA) end)
    pcall(function() h:SetAttribute("Stamina",    HORSE_MAX_STAMINA) end)
    pcall(function() h:SetAttribute("RegenRate",  HORSE_REGEN) end)
    pcall(function() h:SetAttribute("MaxSpeed",   Horse.MaxSpeed) end)
end

-- ============================================================
-- FEATURE: PLAYER ESP (game.Workspace.World.Characters)
-- ============================================================

local function localRootPos()
    local char = LocalPlayer.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then return hrp.Position end
    end
    return nil
end

-- Approx glyph widths for sizing the pill backgrounds (Matcha Text has no
-- measurable width). Names are proportional with many narrow chars, so the
-- bold estimate is smaller than the digit-heavy distance estimate — otherwise
-- long names get a big empty gap inside the pill.
local CHAR_W_BOLD = 6.1
local CHAR_W_REG  = 7

-- One ESP entry per character: an 8-segment corner box + name/distance text
-- (with optional bg) + tracer. Created ONCE per model by the periodic scan;
-- the per-frame update only repositions, like Menu.lua's playerEsp.
local function makeEspObj(model)
    local boxLines = {}
    for i = 1, 8 do
        local l = Drawing.new("Line")
        l.Thickness = 1; l.Color = PLAYER_ESP.Color; l.Visible = false; l.ZIndex = 1
        boxLines[i] = l
    end
    local nameBg = Drawing.new("Square")
    nameBg.Filled = true; nameBg.Color = Color3.fromRGB(22, 22, 26); nameBg.Transparency = 0.82
    nameBg.Corner = 4; nameBg.Visible = false; nameBg.ZIndex = 1
    local distBg = Drawing.new("Square")
    distBg.Filled = true; distBg.Color = Color3.fromRGB(48, 48, 55); distBg.Transparency = 0.82
    distBg.Corner = 4; distBg.Visible = false; distBg.ZIndex = 1
    local name = Drawing.new("Text")
    name.Size = 13; name.Center = false; name.Outline = false; name.Font = Drawing.Fonts.SystemBold
    name.Color = PLAYER_ESP.Color; name.Visible = false; name.ZIndex = 2
    local dist = Drawing.new("Text")
    dist.Size = 13; dist.Center = false; dist.Outline = false; dist.Font = Drawing.Fonts.System
    dist.Color = PLAYER_ESP.Color; dist.Visible = false; dist.ZIndex = 2
    local tracer = Drawing.new("Line")
    tracer.Thickness = 1; tracer.Color = PLAYER_ESP.Color; tracer.Visible = false; tracer.ZIndex = 1
    return { model = model, hrp = nil, displayName = nil,
             boxLines = boxLines, nameBg = nameBg, distBg = distBg, name = name, dist = dist, tracer = tracer, cache = {} }
end

local function setBoxVis(o, want)
    if o.cache.boxVis ~= want then
        o.cache.boxVis = want
        for i = 1, 8 do pcall(function() o.boxLines[i].Visible = want end) end
    end
end

-- Hide everything + reset the visibility cache so a later show re-issues it.
local function hideEspObj(o)
    setBoxVis(o, false)
    pcall(function() o.nameBg.Visible = false end)
    pcall(function() o.distBg.Visible = false end)
    pcall(function() o.name.Visible = false end)
    pcall(function() o.dist.Visible = false end)
    pcall(function() o.tracer.Visible = false end)
    o.cache.bgVis, o.cache.distBgVis, o.cache.nameVis, o.cache.distVis, o.cache.tracerVis = false, false, false, false, false
end
local function removeEspObj(o)
    for i = 1, 8 do pcall(function() o.boxLines[i]:Remove() end) end
    pcall(function() o.nameBg:Remove() end)
    pcall(function() o.distBg:Remove() end)
    pcall(function() o.name:Remove() end)
    pcall(function() o.dist:Remove() end)
    pcall(function() o.tracer:Remove() end)
end

-- Set Visible only when it actually changes (each write is a Matcha call).
local function setVis(o, el, key, want)
    if o.cache[key] ~= want then o.cache[key] = want; pcall(function() el.Visible = want end) end
end

local function setLine(l, x1, y1, x2, y2)
    pcall(function() l.From = Vector2.new(x1, y1); l.To = Vector2.new(x2, y2) end)
end

-- Position the 8 corner segments of a [x,y,w,h] box.
local function setBox(o, x, y, w, h)
    local L = math.min(w, h) * 0.28
    if L < 3 then L = 3 elseif L > 16 then L = 16 end
    local x2, y2 = x + w, y + h
    local b = o.boxLines
    setLine(b[1], x,  y,  x + L, y);   setLine(b[2], x,  y,  x,  y + L)   -- TL
    setLine(b[3], x2, y,  x2 - L, y);  setLine(b[4], x2, y,  x2, y + L)   -- TR
    setLine(b[5], x,  y2, x + L, y2);  setLine(b[6], x,  y2, x,  y2 - L)  -- BL
    setLine(b[7], x2, y2, x2 - L, y2); setLine(b[8], x2, y2, x2, y2 - L)  -- BR
end

-- Periodic (not per-frame) scan: register objects for new characters, drop
-- objects whose model left. Keeps the per-frame update allocation-free.
local function espScan()
    local world = Workspace:FindFirstChild("World")
    local chars = world and world:FindFirstChild("Characters")
    if not chars then return end
    local present = {}
    for _, model in ipairs(chars:GetChildren()) do
        if model.Name ~= LocalPlayer.Name
           and (model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart) then
            present[model] = true
            if not PLAYER_ESP.Objects[model] then
                PLAYER_ESP.Objects[model] = makeEspObj(model)
            end
        end
    end
    for model, o in pairs(PLAYER_ESP.Objects) do
        if not present[model] then removeEspObj(o); PLAYER_ESP.Objects[model] = nil end
    end
end

-- Per-frame: reposition the already-registered objects. No GetChildren, no
-- table allocation, no sort — caches the HRP reference per object.
local function espUpdate()
    if not Features.PlayerESP then
        for _, o in pairs(PLAYER_ESP.Objects) do hideEspObj(o) end
        return
    end
    local myPos = localRootPos()
    local col = PLAYER_ESP.Color
    local vpW, vpH = 2560, 1440
    pcall(function() local c = Workspace.CurrentCamera; vpW, vpH = c.ViewportSize.X, c.ViewportSize.Y end)

    for model, o in pairs(PLAYER_ESP.Objects) do
        local hide = false
        if not model.Parent then
            hide = true
        else
            local hrp = o.hrp
            if not hrp or not hrp.Parent then
                hrp = model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart
                o.hrp = hrp
            end
            local pos
            if hrp then pcall(function() pos = hrp.Position end) end
            if not pos then
                hide = true
            else
                local d = myPos and (pos - myPos).Magnitude or nil
                if d and d > PLAYER_ESP.MaxDistance then
                    hide = true
                else
                    local headS, onHead = WorldToScreen(pos + Vector3.new(0, 3, 0))
                    local footS, onFoot = WorldToScreen(pos - Vector3.new(0, 3, 0))
                    if not (onHead and onFoot and headS and footS) then
                        hide = true
                    else
                        local cache = o.cache
                        if cache.col ~= col then
                            cache.col = col
                            for i = 1, 8 do pcall(function() o.boxLines[i].Color = col end) end
                            pcall(function() o.name.Color = col end)
                            pcall(function() o.dist.Color = col end)
                            pcall(function() o.tracer.Color = col end)
                        end

                        -- Accurate box: use the midpoint of the head/foot
                        -- projections for the centre so it stays on the player.
                        local topY = headS.Y
                        local boxH = footS.Y - topY
                        local boxW = boxH * 0.42
                        local centerX = (headS.X + footS.X) / 2
                        local boxX = centerX - boxW / 2

                        if PLAYER_ESP.ShowBox and boxH > 0 then
                            setBox(o, boxX, topY, boxW, boxH)
                            setBoxVis(o, true)
                        else setBoxVis(o, false) end

                        -- Resolve "FirstName (username)" once.
                        if not o.displayName then
                            local fn
                            pcall(function() fn = model:GetAttribute("FirstName") end)
                            if fn == nil then
                                local fc = model:FindFirstChild("FirstName")
                                if fc then pcall(function() fn = fc.Value end) end
                            end
                            if type(fn) == "string" and fn ~= "" then
                                o.displayName = fn .. " (" .. model.Name .. ")"
                            end
                        end

                        -- Name and distance each get their OWN pill that expands
                        -- to fit its text, separated by a gap (detached).
                        local nameStr = PLAYER_ESP.ShowName and (o.displayName or model.Name) or ""
                        local distStr = (PLAYER_ESP.ShowDistance and d) and (math.floor(d + 0.5) .. "m") or ""
                        local PILL_H, PAD, PILL_GAP = 18, 6, 6
                        local nameBoxW = (nameStr ~= "") and (#nameStr * CHAR_W_BOLD + PAD * 2) or 0
                        local distBoxW = (distStr ~= "") and (#distStr * CHAR_W_REG + PAD * 2) or 0
                        local interGap = (nameBoxW > 0 and distBoxW > 0) and PILL_GAP or 0
                        local groupW = nameBoxW + interGap + distBoxW
                        local pillY = topY - PILL_H - 6
                        local groupX = centerX - groupW / 2
                        local distBoxX = groupX + nameBoxW + interGap

                        -- name pill + text
                        if PLAYER_ESP.ShowNameBg and nameBoxW > 0 then
                            pcall(function()
                                o.nameBg.Position = Vector2.new(groupX, pillY)
                                o.nameBg.Size = Vector2.new(nameBoxW, PILL_H)
                            end)
                            setVis(o, o.nameBg, "bgVis", true)
                        else setVis(o, o.nameBg, "bgVis", false) end
                        if nameStr ~= "" then
                            pcall(function() o.name.Position = Vector2.new(groupX + PAD, pillY + 2) end)
                            if cache.nameTxt ~= nameStr then cache.nameTxt = nameStr; pcall(function() o.name.Text = nameStr end) end
                            setVis(o, o.name, "nameVis", true)
                        else setVis(o, o.name, "nameVis", false) end

                        -- distance pill + text (separate background)
                        if PLAYER_ESP.ShowNameBg and distBoxW > 0 then
                            pcall(function()
                                o.distBg.Position = Vector2.new(distBoxX, pillY)
                                o.distBg.Size = Vector2.new(distBoxW, PILL_H)
                            end)
                            setVis(o, o.distBg, "distBgVis", true)
                        else setVis(o, o.distBg, "distBgVis", false) end
                        if distStr ~= "" then
                            pcall(function() o.dist.Position = Vector2.new(distBoxX + PAD, pillY + 2) end)
                            if cache.distTxt ~= distStr then cache.distTxt = distStr; pcall(function() o.dist.Text = distStr end) end
                            setVis(o, o.dist, "distVis", true)
                        else setVis(o, o.dist, "distVis", false) end

                        if PLAYER_ESP.ShowTracer then
                            pcall(function()
                                o.tracer.From = Vector2.new(vpW / 2, vpH)
                                o.tracer.To = Vector2.new(centerX, footS.Y)
                            end)
                            setVis(o, o.tracer, "tracerVis", true)
                        else setVis(o, o.tracer, "tracerVis", false) end
                    end
                end
            end
        end
        if hide then hideEspObj(o) end
    end
end

-- ============================================================
-- CONFIG SAVE / LOAD / RESET
-- ============================================================

saveConfig = function()
    if type(writefile) ~= "function" then toast("writefile unavailable"); return end
    local data = {
        binds = { toggle = GUI.ToggleKey, close = GUI.CloseKey },
        horse = { boost = Features.HorseBoost, maxSpeed = Horse.MaxSpeed },
        esp = {
            enabled = Features.PlayerESP,
            r = PLAYER_ESP.ColorR, g = PLAYER_ESP.ColorG, b = PLAYER_ESP.ColorB,
            maxDistance = PLAYER_ESP.MaxDistance,
            box = PLAYER_ESP.ShowBox, name = PLAYER_ESP.ShowName, namebg = PLAYER_ESP.ShowNameBg,
            distance = PLAYER_ESP.ShowDistance, tracer = PLAYER_ESP.ShowTracer,
        },
    }
    pcall(function()
        if type(makefolder) == "function" and type(isfolder) == "function" and not isfolder(CONFIG_DIR) then
            makefolder(CONFIG_DIR)
        end
        writefile(CONFIG_PATH, HttpService:JSONEncode(data))
    end)
end

loadConfig = function()
    if type(readfile) ~= "function" or type(isfile) ~= "function" then return end
    if not isfile(CONFIG_PATH) then return end
    local ok, raw = pcall(readfile, CONFIG_PATH)
    if not (ok and raw) then return end
    local okJ, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not (okJ and type(data) == "table") then return end

    if type(data.binds) == "table" then
        if type(data.binds.toggle) == "number" then GUI.ToggleKey = data.binds.toggle end
        if type(data.binds.close)  == "number" then GUI.CloseKey  = data.binds.close  end
    end
    if type(data.horse) == "table" then
        if type(data.horse.boost)    == "boolean" then Features.HorseBoost = data.horse.boost end
        if type(data.horse.maxSpeed) == "number"  then Horse.MaxSpeed = data.horse.maxSpeed end
    end
    if type(data.esp) == "table" then
        local e = data.esp
        if type(e.enabled)     == "boolean" then Features.PlayerESP       = e.enabled end
        if type(e.r)           == "number"  then PLAYER_ESP.ColorR        = e.r end
        if type(e.g)           == "number"  then PLAYER_ESP.ColorG        = e.g end
        if type(e.b)           == "number"  then PLAYER_ESP.ColorB        = e.b end
        if type(e.maxDistance) == "number"  then PLAYER_ESP.MaxDistance   = e.maxDistance end
        if type(e.box)         == "boolean" then PLAYER_ESP.ShowBox       = e.box end
        if type(e.name)        == "boolean" then PLAYER_ESP.ShowName      = e.name end
        if type(e.namebg)      == "boolean" then PLAYER_ESP.ShowNameBg    = e.namebg end
        if type(e.distance)    == "boolean" then PLAYER_ESP.ShowDistance  = e.distance end
        if type(e.tracer)      == "boolean" then PLAYER_ESP.ShowTracer    = e.tracer end
        espRecolor()
    end
end

resetConfig = function()
    GUI.ToggleKey = 0x72; GUI.CloseKey = 0x23
    Features.HorseBoost = false; Features.PlayerESP = false
    if Horse.SnapTaken then restoreHorse() end
    Horse.MaxSpeed = 65
    PLAYER_ESP.ColorR, PLAYER_ESP.ColorG, PLAYER_ESP.ColorB = 255, 255, 255
    PLAYER_ESP.MaxDistance = 100000
    PLAYER_ESP.ShowBox, PLAYER_ESP.ShowName, PLAYER_ESP.ShowDistance, PLAYER_ESP.ShowTracer = true, true, true, false
    PLAYER_ESP.ShowNameBg = true
    espRecolor()
end

-- ============================================================
-- UNLOAD
-- ============================================================

local function UnloadScript()
    GUI.Running = false
    if Horse.SnapTaken then pcall(restoreHorse) end
    for _, el in ipairs(GUI.Elements) do pcall(function() el:Remove() end) end
    for _, el in ipairs(GUI.ContentElements) do pcall(function() el:Remove() end) end
    for _, el in ipairs(GUI.SubTabElements) do pcall(function() el:Remove() end) end
    for _, o in pairs(PLAYER_ESP.Objects) do removeEspObj(o) end
    GUI.Elements, GUI.ContentElements, GUI.SubTabElements = {}, {}, {}
    GUI.Clickables, GUI.SubTabClickables, PLAYER_ESP.Objects = {}, {}, {}
    _G.VERFALL = nil
end

-- ============================================================
-- FEATURE LOOP (independent of input — never blocks clicks)
-- ============================================================

local function FeatureLoop()
    -- Horse boost is applied on-demand, not looped. ESP: scan for new/gone
    -- characters every ~0.5s, reposition every tick (Menu.lua's pattern).
    local f = 0
    while GUI.Running do
        if Features.PlayerESP then
            f = f + 1
            if f % 10 == 1 then pcall(espScan) end
        end
        pcall(espUpdate)
        task.wait(0.03)  -- ~33 Hz reposition; per-tick work is now allocation-free
    end
end

-- ============================================================
-- INPUT LOOP (light + fast)
-- ============================================================

local function InputLoop()
    while GUI.Running do
        -- close key (rising edge; ignore a key held from launch)
        local closeDown = iskeypressed(GUI.CloseKey)
        if GUI.CloseKeyReady then
            if closeDown and not GUI.WasCloseDown then UnloadScript(); return end
        elseif not closeDown then GUI.CloseKeyReady = true end
        GUI.WasCloseDown = closeDown

        -- keybind capture
        if GUI.ListeningForCloseKey then
            for _, vk in ipairs(VK_SCAN) do
                if iskeypressed(vk) then
                    GUI.CloseKey = vk; GUI.ListeningForCloseKey = false
                    GUI.CloseKeyReady = false; GUI.WasCloseDown = true
                    if GUI.SelectedPage == "Settings" then CreateContent("Settings") end
                    task.wait(0.2); break
                end
            end
        end
        if GUI.ListeningForKey then
            for _, vk in ipairs(VK_SCAN) do
                if iskeypressed(vk) then
                    GUI.ToggleKey = vk; GUI.ListeningForKey = false
                    if GUI.SelectedPage == "Settings" then CreateContent("Settings") end
                    task.wait(0.2); break
                end
            end
            GUI.WasToggleDown = iskeypressed(GUI.ToggleKey)
            task.wait(0.012)
        else
            local toggleDown = iskeypressed(GUI.ToggleKey)
            if toggleDown and not GUI.WasToggleDown then
                GUI.Visible = not GUI.Visible
                for _, el in ipairs(GUI.Elements) do pcall(function() el.Visible = GUI.Visible end) end
                if GUI.Visible then CreateContent(GUI.SelectedPage) else ClearContent(); ClearSubTabs() end
            end
            GUI.WasToggleDown = toggleDown

            if GUI.Visible then
                local mx, my = Mouse.X, Mouse.Y
                local mouseDown = ismouse1pressed()
                local justPressed = mouseDown and not GUI.WasMouseDown
                local onHeader = IsInside(mx, my, Config.WinX, Config.WinY, Config.WinW, Config.HeaderH)

                -- drag
                if GUI.Dragging then
                    if mouseDown then
                        local ddx = (mx - GUI.DragOffsetX) - Config.WinX
                        local ddy = (my - GUI.DragOffsetY) - Config.WinY
                        if ddx ~= 0 or ddy ~= 0 then MoveWindow(ddx, ddy) end
                    else GUI.Dragging = false end
                end

                -- continuous slider drag
                if GUI.SliderDragging and mouseDown then
                    pcall(function() GUI.SliderDragging.onClick(mx) end)
                elseif not mouseDown then
                    GUI.SliderDragging = nil
                end

                if justPressed then
                    local handled = false

                    -- subtab clickables
                    for _, c in ipairs(GUI.SubTabClickables) do
                        if IsInside(mx, my, c.x, c.y, c.w, c.h) then c.onClick(); handled = true; break end
                    end

                    -- content clickables
                    if not handled then
                        for _, c in ipairs(GUI.Clickables) do
                            if IsInside(mx, my, c.x, c.y, c.w, c.h) then
                                if c.isSlider then
                                    c.onClick(mx)
                                    GUI.SliderDragging = c
                                else
                                    if c.hover and c.hover.el then pcall(function() c.hover.el.Color = lighten(c.hover.base, 0.18) end) end
                                    c.onClick()
                                end
                                handled = true; break
                            end
                        end
                    end

                    -- nav tabs (instant switch + cosmetic underline slide)
                    if not handled then
                        for _, btn in ipairs(GUI.NavButtons) do
                            local hx, hy, hw, hh = navHitBounds(btn)
                            if IsInside(mx, my, hx, hy, hw, hh) then
                                handled = true
                                if GUI.SelectedPage ~= btn.Key then
                                    GUI.SelectedPage = btn.Key
                                    for _, b in ipairs(GUI.NavButtons) do UpdateNavButton(b, b.Key == GUI.SelectedPage, false) end
                                    CreateContent(btn.Key)
                                    animateMainTabUnderline(btn)
                                end
                                break
                            end
                        end
                    end

                    -- header drag
                    if not handled and onHeader and not GUI.Dragging then
                        GUI.Dragging = true
                        GUI.DragOffsetX = mx - Config.WinX
                        GUI.DragOffsetY = my - Config.WinY
                    end
                end

                -- hover lighten
                for _, c in ipairs(GUI.Clickables) do
                    if c.hover and c.hover.el then
                        local over = IsInside(mx, my, c.x, c.y, c.w, c.h)
                        if over and not c.hover.hovered then
                            pcall(function() c.hover.el.Color = lighten(c.hover.base, 0.10) end)
                            c.hover.hovered = true
                        elseif (not over) and c.hover.hovered then
                            pcall(function() c.hover.el.Color = c.hover.base end)
                            c.hover.hovered = false
                        end
                    end
                end
                for _, btn in ipairs(GUI.NavButtons) do
                    local hx, hy, hw, hh = navHitBounds(btn)
                    UpdateNavButton(btn, btn.Key == GUI.SelectedPage, IsInside(mx, my, hx, hy, hw, hh))
                end

                GUI.WasMouseDown = mouseDown
            else
                GUI.WasMouseDown = ismouse1pressed()
            end

            task.wait(0.012)
        end
    end
end

