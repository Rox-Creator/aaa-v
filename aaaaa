-- Format a number compactly: trim trailing zeros, show decimals if < 1
local function fmtNum(n)
    if n == math.floor(n) then return tostring(math.floor(n)) end
    local s = string.format("%.3f", n)
    s = s:gsub("0+$", ""):gsub("%.$", "")
    return s
end

local function buffHintText(key)
    local b = BuffsState[key]
    if not b then return "" end
    -- When this buff is actively being typed, preview the buffer value
    local previewTarget = b.target
    if GUI.ActiveInput == key and GUI.InputBuffer ~= "" then
        local n = tonumber(GUI.InputBuffer)
        if n and n > 0 then previewTarget = n end
    end
    if b.type == "mult" then
        local ratio = previewTarget / math.max(0.0001, b.default)
        local r = (ratio >= 100) and tostring(math.floor(ratio)) or string.format("%.1f", ratio):gsub("%.0$", "")
        local s = ("default: %s | %sx normal"):format(fmtNum(b.default), r)
        if b.clamp then s = s .. " (server clamps to "..fmtNum(b.clamp)..")" end
        return s
    else
        -- "bonus" type — additive bonus to base game value (use ASCII pipe for clean render)
        local s = ("default: %s | pin: %s"):format(fmtNum(b.default), fmtNum(previewTarget))
        if b.clamp then s = s .. " (server clamps to "..fmtNum(b.clamp)..")" end
        return s
    end
end

