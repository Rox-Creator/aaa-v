    local list = buildFilteredEnchantList()
    local totalRows = math.ceil(#list / cols)
    local visibleRows = math.max(1, math.floor((gridH + rowGap) / (cardH + rowGap)))
    local maxScroll = math.max(0, totalRows - visibleRows)
    if GUI.EnchantsScrollOffset > maxScroll then GUI.EnchantsScrollOffset = maxScroll end
    if GUI.EnchantsScrollOffset < 0 then GUI.EnchantsScrollOffset = 0 end

    if #list == 0 then
        local empty = Drawing.new("Text")
        empty.Position = Vector2.new(px + pw / 2, gridY + gridH / 2 - 8)
        empty.Text = GUI.EnchantsData and "No entries match this filter" or "Scanning..."
        empty.Color = Colors.TextMuted; empty.Size = 14
        empty.Font = Drawing.Fonts.System; empty.Center = true
        empty.Outline = false; empty.Visible = true; empty.ZIndex = zb + 3
        table.insert(GUI.EnchantsElements, empty)
    else
        local startRow = GUI.EnchantsScrollOffset
        local endRow = math.min(totalRows - 1, startRow + visibleRows - 1)
        for row = startRow, endRow do
            for col = 0, cols - 1 do
                local idx = row * cols + col + 1
                local item = list[idx]
                if item then
                    local cx = gridX + col * (cardW + colGap)
                    local cy = gridY + (row - startRow) * (cardH + rowGap)
                    local rcol = ENCHANT_RARITY_COLORS[item.rarity] or Colors.TextPrimary

                    -- Card bg
                    local cardBg = Drawing.new("Square")
                    cardBg.Position = Vector2.new(cx, cy); cardBg.Size = Vector2.new(cardW, cardH)
                    cardBg.Color = Color3.fromRGB(22, 22, 26); cardBg.Filled = true
                    cardBg.Corner = 5; cardBg.Visible = true; cardBg.ZIndex = zb + 2
                    table.insert(GUI.EnchantsElements, cardBg)
                    local cardBrd = Drawing.new("Square")
                    cardBrd.Position = Vector2.new(cx, cy); cardBrd.Size = Vector2.new(cardW, cardH)
                    cardBrd.Color = Color3.fromRGB(40, 40, 46); cardBrd.Filled = false
                    cardBrd.Corner = 5; cardBrd.Thickness = 1
                    cardBrd.Visible = true; cardBrd.ZIndex = zb + 3
                    table.insert(GUI.EnchantsElements, cardBrd)

                    -- Rarity strip across bottom
                    local stripH = 4
                    local strip = Drawing.new("Square")
                    strip.Position = Vector2.new(cx + 1, cy + cardH - stripH - 1)
                    strip.Size = Vector2.new(cardW - 2, stripH)
                    strip.Color = rcol; strip.Filled = true
                    strip.Visible = true; strip.ZIndex = zb + 4
                    table.insert(GUI.EnchantsElements, strip)

                    -- Teardrop icon (two filled circles)
                    local orbCx = cx + cardW / 2
                    local orbCy = cy + 50
                    local body = Drawing.new("Circle")
                    body.Position = Vector2.new(orbCx, orbCy + 6); body.Radius = 11
                    body.NumSides = 24; body.Color = rcol
                    body.Filled = true; body.Transparency = 0.85
                    body.Visible = true; body.ZIndex = zb + 4
                    table.insert(GUI.EnchantsElements, body)
                    local tip = Drawing.new("Circle")
                    tip.Position = Vector2.new(orbCx, orbCy - 6); tip.Radius = 6
                    tip.NumSides = 18; tip.Color = rcol
                    tip.Filled = true; tip.Transparency = 0.85
                    tip.Visible = true; tip.ZIndex = zb + 4
                    table.insert(GUI.EnchantsElements, tip)

                    -- Name (bottom)
                    local nameLabel = Drawing.new("Text")
                    nameLabel.Position = Vector2.new(cx + cardW / 2, cy + cardH - 22)
                    nameLabel.Text = item.name
                    nameLabel.Color = Colors.TextPrimary; nameLabel.Size = 12
                    nameLabel.Font = Drawing.Fonts.SystemBold
                    nameLabel.Center = true; nameLabel.Outline = false
                    nameLabel.Visible = true; nameLabel.ZIndex = zb + 5
                    table.insert(GUI.EnchantsElements, nameLabel)

                    -- Rarity tag top-left
                    local rTag = Drawing.new("Text")
                    rTag.Position = Vector2.new(cx + 8, cy + 6); rTag.Text = item.rarity
                    rTag.Color = rcol; rTag.Size = 10
                    rTag.Font = Drawing.Fonts.System; rTag.Center = false
                    rTag.Outline = false; rTag.Visible = true; rTag.ZIndex = zb + 5
                    table.insert(GUI.EnchantsElements, rTag)

                    -- Click → open modal with path detail
                    local capItem = item
                    table.insert(GUI.EnchantsClickables, {
                        x = cx, y = cy, w = cardW, h = cardH,
                        onClick = function()
                            GUI.EnchantsModal = {
                                name = capItem.name, rarity = capItem.rarity, path = capItem.path,
                            }
                            BuildEnchantsPanel()
                        end,
                    })
                end
            end
        end
    end

    -- Scroll arrows on right
    if maxScroll > 0 then
        local sbX = px + pw - 30
        local arrowW, arrowH = 22, 22
        local function arrow(yy, label, onClick)
            local bgB = Drawing.new("Square")
            bgB.Position = Vector2.new(sbX, yy); bgB.Size = Vector2.new(arrowW, arrowH)
            bgB.Color = Color3.fromRGB(34, 34, 40); bgB.Filled = true; bgB.Corner = 3
            bgB.Visible = true; bgB.ZIndex = zb + 5
            table.insert(GUI.EnchantsElements, bgB)
            local txt = Drawing.new("Text")
            txt.Position = Vector2.new(sbX + arrowW / 2, yy + (arrowH - 13) / 1.3)
            txt.Text = label; txt.Color = Colors.TextPrimary; txt.Size = 13
            txt.Font = Drawing.Fonts.SystemBold; txt.Center = true; txt.Outline = false
            txt.Visible = true; txt.ZIndex = zb + 6
            table.insert(GUI.EnchantsElements, txt)
            table.insert(GUI.EnchantsClickables, { x = sbX, y = yy, w = arrowW, h = arrowH, onClick = onClick })
        end
        arrow(gridY, "^", function()
            if GUI.EnchantsScrollOffset > 0 then
                GUI.EnchantsScrollOffset = GUI.EnchantsScrollOffset - 1
                BuildEnchantsPanel()
            end
        end)
        arrow(gridY + gridH - arrowH, "v", function()
            if GUI.EnchantsScrollOffset < maxScroll then
                GUI.EnchantsScrollOffset = GUI.EnchantsScrollOffset + 1
                BuildEnchantsPanel()
            end
        end)
        local posTxt = Drawing.new("Text")
        posTxt.Position = Vector2.new(sbX + arrowW / 2, gridY + gridH / 2 - 8)
        posTxt.Text = string.format("%d/%d", GUI.EnchantsScrollOffset + 1, totalRows)
        posTxt.Color = Colors.TextMuted; posTxt.Size = 10
        posTxt.Font = Drawing.Fonts.System; posTxt.Center = true
        posTxt.Outline = false; posTxt.Visible = true; posTxt.ZIndex = zb + 6
        table.insert(GUI.EnchantsElements, posTxt)
    end

    -- Modal popup (if open)
    if GUI.EnchantsModal then
        local m = GUI.EnchantsModal
        local mw, mh = 460, 200
        local mx = px + (pw - mw) / 2
        local my = py + (ph - mh) / 2
        local zbm = zb + 20

        -- Dim the panel behind the modal
        local dim = Drawing.new("Square")
        dim.Position = Vector2.new(px, py); dim.Size = Vector2.new(pw, ph)
        dim.Color = Color3.fromRGB(0, 0, 0); dim.Filled = true
        dim.Transparency = 0.4; dim.Visible = true; dim.ZIndex = zbm
        table.insert(GUI.EnchantsElements, dim)

        local mbg = Drawing.new("Square")
        mbg.Position = Vector2.new(mx, my); mbg.Size = Vector2.new(mw, mh)
        mbg.Color = Color3.fromRGB(22, 22, 28); mbg.Filled = true; mbg.Corner = 6
        mbg.Visible = true; mbg.ZIndex = zbm + 1
        table.insert(GUI.EnchantsElements, mbg)
        local mbrd = Drawing.new("Square")
        mbrd.Position = Vector2.new(mx, my); mbrd.Size = Vector2.new(mw, mh)
        mbrd.Color = ENCHANT_RARITY_COLORS[m.rarity] or Colors.AccentRed
        mbrd.Filled = false; mbrd.Corner = 6; mbrd.Thickness = 2
        mbrd.Visible = true; mbrd.ZIndex = zbm + 2
        table.insert(GUI.EnchantsElements, mbrd)

        local mTitle = Drawing.new("Text")
        mTitle.Position = Vector2.new(mx + 16, my + 14); mTitle.Text = m.name
        mTitle.Color = Colors.TextPrimary; mTitle.Size = 18
        mTitle.Font = Drawing.Fonts.SystemBold; mTitle.Center = false
        mTitle.Outline = false; mTitle.Visible = true; mTitle.ZIndex = zbm + 3
        table.insert(GUI.EnchantsElements, mTitle)

        local mRar = Drawing.new("Text")
        mRar.Position = Vector2.new(mx + 16, my + 40); mRar.Text = "Rarity: " .. m.rarity
        mRar.Color = ENCHANT_RARITY_COLORS[m.rarity] or Colors.TextMuted; mRar.Size = 14
        mRar.Font = Drawing.Fonts.SystemBold; mRar.Center = false
        mRar.Outline = false; mRar.Visible = true; mRar.ZIndex = zbm + 3
        table.insert(GUI.EnchantsElements, mRar)

        -- Description (from TALENT_DESC table)
        local desc = TALENT_DESC[m.name]
        if desc then
            local dLbl = Drawing.new("Text")
            dLbl.Position = Vector2.new(mx + 16, my + 66); dLbl.Text = "Description:"
            dLbl.Color = Colors.TextMuted; dLbl.Size = 12
            dLbl.Font = Drawing.Fonts.System; dLbl.Center = false
            dLbl.Outline = false; dLbl.Visible = true; dLbl.ZIndex = zbm + 3
            table.insert(GUI.EnchantsElements, dLbl)

            -- Word-wrap description (~50 chars/line)
            local lineLen = 50
            local lineY = my + 84
            local i = 1
            while i <= #desc do
                local seg = desc:sub(i, i + lineLen - 1)
                local segLbl = Drawing.new("Text")
                segLbl.Position = Vector2.new(mx + 16, lineY); segLbl.Text = seg
                segLbl.Color = Colors.TextPrimary; segLbl.Size = 13
                segLbl.Font = Drawing.Fonts.System; segLbl.Center = false
                segLbl.Outline = false; segLbl.Visible = true; segLbl.ZIndex = zbm + 3
                table.insert(GUI.EnchantsElements, segLbl)
                lineY = lineY + 16
                i = i + lineLen
                if lineY > my + mh - 50 then break end
            end
        else
            local noDesc = Drawing.new("Text")
            noDesc.Position = Vector2.new(mx + 16, my + 66)
            noDesc.Text = "Description not yet extracted."
            noDesc.Color = Colors.TextMuted; noDesc.Size = 12
            noDesc.Font = Drawing.Fonts.System; noDesc.Center = false
            noDesc.Outline = false; noDesc.Visible = true; noDesc.ZIndex = zbm + 3
            table.insert(GUI.EnchantsElements, noDesc)
        end

        -- Path at the bottom (small/muted)
        local pathLbl = Drawing.new("Text")
        pathLbl.Position = Vector2.new(mx + 16, my + mh - 22)
        pathLbl.Text = "[" .. m.rarity .. "]"
        pathLbl.Color = ENCHANT_RARITY_COLORS[m.rarity] or Colors.TextMuted
        pathLbl.Size = 11; pathLbl.Font = Drawing.Fonts.System
        pathLbl.Center = false; pathLbl.Outline = false
        pathLbl.Visible = true; pathLbl.ZIndex = zbm + 3
        table.insert(GUI.EnchantsElements, pathLbl)

        -- Close button
        local mcX = mx + mw - 28
        local mcY = my + 8
        local mClose = Drawing.new("Text")
        mClose.Position = Vector2.new(mcX + 6, mcY + 2); mClose.Text = "X"
        mClose.Color = Colors.AccentRed; mClose.Size = 17
        mClose.Font = Drawing.Fonts.SystemBold; mClose.Center = false
        mClose.Outline = false; mClose.Visible = true; mClose.ZIndex = zbm + 3
        table.insert(GUI.EnchantsElements, mClose)
        table.insert(GUI.EnchantsClickables, {
            x = mcX, y = mcY, w = 24, h = 24,
            onClick = function() GUI.EnchantsModal = nil; BuildEnchantsPanel() end,
        })
    end
end

