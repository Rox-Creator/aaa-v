-- ============================================================
-- SPRINT (Matcha-compatible — uses AssemblyLinearVelocity write since
-- Humanoid.WalkSpeed is blocked by Matcha's property wrapper.
-- Only applies when sprint key + a movement key are both held.)
-- ============================================================

-- Sprint = Matcha's "Slippery" mode replicated: pin HRP.AssemblyLinearVelocity
-- to (cameraForward * speed) each Heartbeat while Shift+WASD held. Preserves
-- Y so jump/gravity still works. This is the same mechanic Matcha uses
-- internally — runs at 60Hz via Heartbeat (not the 33Hz FeatureLoop).
local function applySprintTick()
    if not Features.SprintSpeed then return end
    if not UIS:IsKeyDown(Enum.KeyCode.LeftShift) then return end

    local W = UIS:IsKeyDown(Enum.KeyCode.W)
    local A = UIS:IsKeyDown(Enum.KeyCode.A)
    local S = UIS:IsKeyDown(Enum.KeyCode.S)
    local D = UIS:IsKeyDown(Enum.KeyCode.D)
    if not (W or A or S or D) then return end

    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local cf
    pcall(function() cf = Workspace.CurrentCamera.CFrame end)
    if not cf then return end
    local fwd = Vector3.new(cf.LookVector.X, 0, cf.LookVector.Z)
    if fwd.Magnitude < 0.01 then return end
    fwd = fwd.Unit
    local right = Vector3.new(fwd.Z, 0, -fwd.X)

    local mv = Vector3.new(0, 0, 0)
    if W then mv = mv + fwd end
    if S then mv = mv - fwd end
    if D then mv = mv + right end
    if A then mv = mv - right end
    if mv.Magnitude < 0.1 then return end
    mv = mv.Unit

    -- Preserve Y velocity so jumping/falling still works naturally.
    local cy = 0
    pcall(function() cy = hrp.AssemblyLinearVelocity.Y end)
    pcall(function()
        hrp.AssemblyLinearVelocity = Vector3.new(mv.X * Sprint.Speed, cy, mv.Z * Sprint.Speed)
    end)
end

