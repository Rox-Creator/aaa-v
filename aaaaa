-- Buff number-input key handler: digits 0-9 append, Backspace deletes,
-- Enter commits, Escape cancels.
-- VK codes: 0x30-0x39 = digits, 0x60-0x69 = numpad digits, 0x08 = Back, 0x0D = Enter, 0x1B = Esc
local NUM_VKS = {
    [0x30]="0",[0x31]="1",[0x32]="2",[0x33]="3",[0x34]="4",
    [0x35]="5",[0x36]="6",[0x37]="7",[0x38]="8",[0x39]="9",
    [0x60]="0",[0x61]="1",[0x62]="2",[0x63]="3",[0x64]="4",
    [0x65]="5",[0x66]="6",[0x67]="7",[0x68]="8",[0x69]="9",
    -- Decimal point support: regular . and numpad .
    [0xBE]=".",[0x6E]=".",
}

local function commitBuffInput()
    local key = GUI.ActiveInput
    if not key then return end
    local b = BuffsState[key]
    if not b then GUI.ActiveInput = nil; GUI.InputBuffer = ""; return end
    local n = tonumber(GUI.InputBuffer)
    if n and n > 0 then
        n = math.min(n, b.max or 100000)
        b.target = n
        -- If buff is currently enabled, the Heartbeat pin will pick up new target automatically
    end
    GUI.ActiveInput = nil
    GUI.InputBuffer = ""
    GUI.InputLastKey = {}
    CreateContent(GUI.SelectedPage)
end

local function cancelBuffInput()
    GUI.ActiveInput = nil
    GUI.InputBuffer = ""
    GUI.InputLastKey = {}
    CreateContent(GUI.SelectedPage)
end

-- Shared GUI show/hide. Called from BOTH the poll loop (rising edge) and the
-- UIS.InputBegan event (which re-checks the real F3 state in laggy servers where the
-- poll loop stretches and drops spammed taps). The 0.18s debounce dedupes so the two
-- paths can't double-toggle the same press. Visibility only — never unloads.
local function doToggleVisibility()
    if tick() - (GUI._lastToggleAt or 0) < 0.18 then return end
    GUI._lastToggleAt = tick()
    GUI.Visible = not GUI.Visible
    for _, el in ipairs(GUI.Elements) do pcall(function() el.Visible = GUI.Visible end) end
    for _, el in ipairs(GUI.RSDiffElements)   do pcall(function() el.Visible = GUI.Visible and GUI.RSDiffOpen end) end
    for _, el in ipairs(GUI.EnchantsElements) do pcall(function() el.Visible = GUI.Visible and GUI.EnchantsOpen end) end
    if GUI.Visible then CreateContent(GUI.SelectedPage) else ClearContent(); ClearSubTabs() end
end

-- Event-driven click dispatch. Pulled out of the poll loop so UIS.InputBegan can
-- fire it the instant a click happens. In laggy servers the poll loop's task.wait
-- stretches to the frame time (100-300ms), so a click that goes down+up between
-- two polls was silently dropped — the "have to click 20 times" bug. The event
-- path catches every physical press exactly once regardless of frame rate.
local function processMousePress(mx, my)
    if not GUI.Visible then return end
    local onHeader = IsInside(mx, my, Config.WinX, Config.WinY, Config.WinW, Config.HeaderH)
    local handled = false

    -- Enchants panel clickables (highest priority among floats)
    if GUI.EnchantsOpen then
        for _, c in ipairs(GUI.EnchantsClickables) do
            if IsInside(mx, my, c.x, c.y, c.w, c.h) then
                pcall(c.onClick)
                handled = true; break
            end
        end
        if not handled then
            local hx, hy, hw, hh = GUI.EnchantsX, GUI.EnchantsY, GUI.EnchantsW, 34
            if IsInside(mx, my, hx, hy, hw, hh) then
                GUI.EnchantsDragging = true
                GUI.EnchantsDragOffsetX = mx - GUI.EnchantsX
                GUI.EnchantsDragOffsetY = my - GUI.EnchantsY
                handled = true
            end
        end
    end

    -- RS Diff panel clickables
    if not handled and GUI.RSDiffOpen then
        for _, c in ipairs(GUI.RSDiffClickables) do
            if IsInside(mx, my, c.x, c.y, c.w, c.h) then
                pcall(c.onClick)
                handled = true; break
            end
        end
        if not handled then
            local hx, hy, hw, hh = GUI.RSDiffX, GUI.RSDiffY, GUI.RSDiffW, 34
            if IsInside(mx, my, hx, hy, hw, hh) then
                GUI.RSDiffDragging = true
                GUI.RSDiffDragOffsetX = mx - GUI.RSDiffX
                GUI.RSDiffDragOffsetY = my - GUI.RSDiffY
                handled = true
            end
        end
    end

    if not handled then
        for _, c in ipairs(GUI.SubTabClickables) do
            if IsInside(mx, my, c.x, c.y, c.w, c.h) then c.onClick(); handled = true; break end
        end
    end
    if not handled then
        for _, c in ipairs(GUI.Clickables) do
            if IsInside(mx, my, c.x, c.y, c.w, c.h) then
                if c.isSlider then
                    c.onClick(mx)
                    GUI.SliderDragging = c
                else
                    if c.hover and c.hover.el then pcall(function() c.hover.el.Color = lighten(c.hover.base, 0.18) end) end
                    c.onClick()
                end
                handled = true; break
            end
        end
    end
    if not handled then
        for _, btn in ipairs(GUI.NavButtons) do
            local hx, hy, hw, hh = navHitBounds(btn)
            if IsInside(mx, my, hx, hy, hw, hh) then
                handled = true
                if GUI.SelectedPage ~= btn.Key then
                    GUI.SelectedPage = btn.Key
                    for _, b in ipairs(GUI.NavButtons) do UpdateNavButton(b, b.Key == GUI.SelectedPage, false) end
                    CreateContent(btn.Key)
                    animateMainTabUnderline(btn)
                end
                break
            end
        end
    end
    if not handled and onHeader and not GUI.Dragging then
        GUI.Dragging = true
        GUI.DragOffsetX = mx - Config.WinX
        GUI.DragOffsetY = my - Config.WinY
    end
end

local function InputLoop()
    while GUI.Running do
        -- Buff numeric input listener (rising-edge per key)
        if GUI.ActiveInput then
            local lastKey = GUI.InputLastKey or {}
            -- digits
            for vk, ch in pairs(NUM_VKS) do
                local down = iskeypressed(vk)
                if down and not lastKey[vk] then
                    -- Allow up to 8 chars now (decimals need room). Prevent multiple dots.
                    local allowDot = (ch == ".") and not GUI.InputBuffer:find(".", 1, true) or ch ~= "."
                    if #GUI.InputBuffer < 8 and allowDot then
                        GUI.InputBuffer = GUI.InputBuffer .. ch
                        CreateContent(GUI.SelectedPage)
                    end
                end
                lastKey[vk] = down
            end
            -- backspace
            local bsDown = iskeypressed(0x08)
            if bsDown and not lastKey[0x08] then
                GUI.InputBuffer = GUI.InputBuffer:sub(1, -2)
                CreateContent(GUI.SelectedPage)
            end
            lastKey[0x08] = bsDown
            -- enter
            local enDown = iskeypressed(0x0D)
            if enDown and not lastKey[0x0D] then
                commitBuffInput()
            end
            lastKey[0x0D] = enDown
            -- escape
            local escDown = iskeypressed(0x1B)
            if escDown and not lastKey[0x1B] then
                cancelBuffInput()
            end
            lastKey[0x1B] = escDown
            GUI.InputLastKey = lastKey
        end

        local closeDown = iskeypressed(GUI.CloseKey)
        if GUI.CloseKeyReady then
            if closeDown and not GUI.WasCloseDown then UnloadScript(); return end
        elseif not closeDown then GUI.CloseKeyReady = true end
        GUI.WasCloseDown = closeDown

        -- ESP keybind toggle (rising edge) — silent, no notification/sound
        -- Skip when typing into a buff input so digits don't double-fire as keybind
        if not GUI.ListeningForESPKey and not GUI.ActiveInput then
            local espDown = iskeypressed(GUI.ESPKey)
            if espDown and not GUI.WasESPDown then
                Features.PlayerESP = not Features.PlayerESP
                if GUI.SelectedPage == "Main" and GUI.SubTab == "Elements" then
                    CreateContent("Main")
                end
            end
            GUI.WasESPDown = espDown
        end
        if GUI.ListeningForCloseKey then
            for _, vk in ipairs(VK_SCAN) do
                if iskeypressed(vk) then
                    GUI.CloseKey = vk; GUI.ListeningForCloseKey = false
                    GUI.CloseKeyReady = false; GUI.WasCloseDown = true
                    if GUI.SelectedPage == "Settings" then CreateContent("Settings") end
                    task.wait(0.2); break
                end
            end
        end
        if GUI.ListeningForESPKey then
            for _, vk in ipairs(VK_SCAN) do
                if iskeypressed(vk) then
                    GUI.ESPKey = vk; GUI.ListeningForESPKey = false
                    GUI.WasESPDown = true
                    -- ESP keybind lives on Main → Elements now
                    if GUI.SelectedPage == "Main" then CreateContent("Main") end
                    task.wait(0.2); break
                end
            end
        end
        if GUI.ListeningForKey then
            for _, vk in ipairs(VK_SCAN) do
                if iskeypressed(vk) then
                    GUI.ToggleKey = vk; GUI.ListeningForKey = false
                    if GUI.SelectedPage == "Settings" then CreateContent("Settings") end
                    task.wait(0.2); break
                end
            end
            GUI.WasToggleDown = iskeypressed(GUI.ToggleKey)
            task.wait(0.012)
        else
            local toggleDown = iskeypressed(GUI.ToggleKey)
            -- Guard against accidental toggle while typing into a buff input
            if toggleDown and not GUI.WasToggleDown and not GUI.ActiveInput then
                doToggleVisibility()
            end
            GUI.WasToggleDown = toggleDown
            if GUI.Visible then
                local mx, my = Mouse.X, Mouse.Y
                local mouseDown = ismouse1pressed()
                local justPressed = mouseDown and not GUI.WasMouseDown
                local onHeader = IsInside(mx, my, Config.WinX, Config.WinY, Config.WinW, Config.HeaderH)

                -- Main window drag
                if GUI.Dragging then
                    if mouseDown then
                        local ddx = (mx - GUI.DragOffsetX) - Config.WinX
                        local ddy = (my - GUI.DragOffsetY) - Config.WinY
                        if ddx ~= 0 or ddy ~= 0 then MoveWindow(ddx, ddy) end
                    else GUI.Dragging = false end
                end

                -- RS Diff panel drag
                if GUI.RSDiffDragging then
                    if mouseDown and GUI.RSDiffOpen then
                        local newX = mx - GUI.RSDiffDragOffsetX
                        local newY = my - GUI.RSDiffDragOffsetY
                        if newX ~= GUI.RSDiffX or newY ~= GUI.RSDiffY then
                            GUI.RSDiffX = newX
                            GUI.RSDiffY = newY
                            BuildRSDiffPanel()
                        end
                    else GUI.RSDiffDragging = false end
                end

                -- Enchants panel drag
                if GUI.EnchantsDragging then
                    if mouseDown and GUI.EnchantsOpen then
                        local newX = mx - GUI.EnchantsDragOffsetX
                        local newY = my - GUI.EnchantsDragOffsetY
                        if newX ~= GUI.EnchantsX or newY ~= GUI.EnchantsY then
                            GUI.EnchantsX = newX
                            GUI.EnchantsY = newY
                            BuildEnchantsPanel()
                        end
                    else GUI.EnchantsDragging = false end
                end

                if GUI.SliderDragging and mouseDown then
                    pcall(function() GUI.SliderDragging.onClick(mx) end)
                elseif not mouseDown then
                    GUI.SliderDragging = nil
                end

                -- Click dispatch is normally handled by the UIS.InputBegan event
                -- (reliable in lag). This poll-based path only runs as a fallback
                -- until the event has proven it delivers mouse presses — then it
                -- stands down so the same click isn't processed twice.
                if justPressed and not GUI._mouseEventAlive then
                    processMousePress(mx, my)
                end
                -- Hover work is expensive (iterates every clickable + nav button).
                -- Only run it when the mouse actually moved OR a drag is happening —
                -- when the cursor is still (most of the time) we skip it entirely.
                if mx ~= GUI._lastHoverX or my ~= GUI._lastHoverY then
                    GUI._lastHoverX, GUI._lastHoverY = mx, my
                    for _, c in ipairs(GUI.Clickables) do
                        if c.hover and c.hover.el then
                            local over = IsInside(mx, my, c.x, c.y, c.w, c.h)
                            if over and not c.hover.hovered then
                                pcall(function() c.hover.el.Color = lighten(c.hover.base, 0.10) end)
                                c.hover.hovered = true
                            elseif (not over) and c.hover.hovered then
                                pcall(function() c.hover.el.Color = c.hover.base end)
                                c.hover.hovered = false
                            end
                        end
                    end
                    for _, btn in ipairs(GUI.NavButtons) do
                        local hx, hy, hw, hh = navHitBounds(btn)
                        UpdateNavButton(btn, btn.Key == GUI.SelectedPage, IsInside(mx, my, hx, hy, hw, hh))
                    end
                end
                GUI.WasMouseDown = mouseDown
            else
                GUI.WasMouseDown = ismouse1pressed()
            end
            -- Poll fast (~83Hz) while the menu is open for snappy clicks; poll
            -- slower (~33Hz) while hidden — the toggle hotkey stays responsive
            -- but we stop burning CPU during normal gameplay.
            task.wait(GUI.Visible and 0.012 or 0.03)
        end
    end
end

