local NAV_CHAR_W = 10
local NAV_HIT_PAD = 6
local function navUnderlineBounds(btn)
    return btn.X - 1, btn.X + 14 + #btn.Label * NAV_CHAR_W
end
local function navHitBounds(btn)
    local l, r = navUnderlineBounds(btn)
    return l - NAV_HIT_PAD, btn.Y, (r - l) + NAV_HIT_PAD * 2, btn.H
end
local function UpdateNavButton(btn, isSelected, isHovered)
    local state = isSelected and "active" or (isHovered and "hover" or "normal")
    if btn._navState == state then return end
    btn._navState = state
    if state == "active" then
        btn.Dot.Color = Colors.AccentRed; btn.Text.Color = Colors.NavActive; btn.Text.Font = Drawing.Fonts.SystemBold
    elseif state == "hover" then
        btn.Dot.Color = Colors.AccentDim; btn.Text.Color = Colors.TextPrimary; btn.Text.Font = Drawing.Fonts.System
    else
        btn.Dot.Color = Colors.TextMuted; btn.Text.Color = Colors.NavNormal; btn.Text.Font = Drawing.Fonts.System
    end
end

local function CreateNavButtons()
    GUI.NavButtons = {}
    local startX = Config.WinX + 110 + 39
