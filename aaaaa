local function DrawCard(x, y, w, h, title, zb)
    local bg = Drawing.new("Square")
    bg.Position = Vector2.new(x, y); bg.Size = Vector2.new(w, h)
    bg.Color = Colors.CardBg; bg.Filled = true; bg.Corner = 5
    bg.Visible = true; bg.ZIndex = zb
    table.insert(GUI.ContentElements, bg)

    local border = Drawing.new("Square")
    border.Position = Vector2.new(x, y); border.Size = Vector2.new(w, h)
    border.Color = Colors.CardBorder; border.Filled = false; border.Corner = 5
    border.Thickness = 1; border.Visible = true; border.ZIndex = zb + 1
    table.insert(GUI.ContentElements, border)

    if title and title ~= "" then
        local t = Drawing.new("Text")
        t.Position = Vector2.new(x + Config.CardPad, y + 10)
        t.Text = title; t.Color = Colors.AccentRed; t.Size = 16
        t.Font = Drawing.Fonts.SystemBold; t.Center = false; t.Outline = false
        t.Visible = true; t.ZIndex = zb + 3
        table.insert(GUI.ContentElements, t)

        local ul = Drawing.new("Line")
