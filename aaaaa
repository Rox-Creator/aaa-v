-- RS Diff floating panel (separate window, draggable by header)
ClearRSDiffPanel = function()
    for _, el in ipairs(GUI.RSDiffElements) do pcall(function() el:Remove() end) end
    GUI.RSDiffElements = {}
    GUI.RSDiffClickables = {}
end

-- Internal: floating panel renderer. Not a "page", lives in its own draw list.
BuildRSDiffPanel = function()
    ClearRSDiffPanel()
    if not GUI.RSDiffOpen then return end

    local zb = 60  -- above main window
    local px, py = GUI.RSDiffX, GUI.RSDiffY
    local pw, ph = GUI.RSDiffW, GUI.RSDiffH
    local headerH = 34

    -- Panel bg + border
    local bg = Drawing.new("Square")
    bg.Position = Vector2.new(px, py); bg.Size = Vector2.new(pw, ph)
    bg.Color = Color3.fromRGB(16, 16, 20); bg.Filled = true
    bg.Corner = 6; bg.Transparency = 0.95
    bg.Visible = true; bg.ZIndex = zb
    table.insert(GUI.RSDiffElements, bg)

    local brd = Drawing.new("Square")
    brd.Position = Vector2.new(px, py); brd.Size = Vector2.new(pw, ph)
    brd.Color = Color3.fromRGB(50, 50, 56); brd.Filled = false
    brd.Corner = 6; brd.Thickness = 1
    brd.Visible = true; brd.ZIndex = zb + 1
    table.insert(GUI.RSDiffElements, brd)

    -- Title bar (drag handle)
    local titleBg = Drawing.new("Square")
    titleBg.Position = Vector2.new(px, py); titleBg.Size = Vector2.new(pw, headerH)
    titleBg.Color = Color3.fromRGB(24, 24, 28); titleBg.Filled = true
    titleBg.Corner = 6; titleBg.Visible = true; titleBg.ZIndex = zb + 1
    table.insert(GUI.RSDiffElements, titleBg)

    local titleFill = Drawing.new("Square")
    titleFill.Position = Vector2.new(px, py + headerH - 6); titleFill.Size = Vector2.new(pw, 6)
    titleFill.Color = Color3.fromRGB(24, 24, 28); titleFill.Filled = true
    titleFill.Visible = true; titleFill.ZIndex = zb + 1
    table.insert(GUI.RSDiffElements, titleFill)

    local titleText = Drawing.new("Text")
    titleText.Position = Vector2.new(px + 14, py + 8); titleText.Text = "ReplicatedStorage Diff"
    titleText.Color = Colors.AccentRed; titleText.Size = 17
    titleText.Font = Drawing.Fonts.SystemBold; titleText.Center = false
    titleText.Outline = false; titleText.Visible = true; titleText.ZIndex = zb + 3
    table.insert(GUI.RSDiffElements, titleText)

    -- Status line
    local statusStr = GUI.RSDiffStatus
    if statusStr == "" then
        if GUI.RSSnapshot then
            statusStr = "Snapshot: " .. GUI.RSSnapshotCount .. " paths, " .. rsTimeAgo(GUI.RSSnapshotAt) .. ". Click Compare to diff."
        else
            statusStr = "No snapshot yet. Click 'Snapshot' or 'Load Saved' to start."
        end
    end
    local status = Drawing.new("Text")
    status.Position = Vector2.new(px + 220, py + 10); status.Text = statusStr
    status.Color = Colors.TextMuted; status.Size = 13
    status.Font = Drawing.Fonts.System; status.Center = false
    status.Outline = false; status.Visible = true; status.ZIndex = zb + 3
    table.insert(GUI.RSDiffElements, status)

    -- Close X (top-right of header)
    local closeX = px + pw - 28
    local closeY = py + 6
    local closeText = Drawing.new("Text")
    closeText.Position = Vector2.new(closeX + 6, closeY + 2); closeText.Text = "X"
    closeText.Color = Colors.AccentRed; closeText.Size = 17
    closeText.Font = Drawing.Fonts.SystemBold; closeText.Center = false
    closeText.Outline = false; closeText.Visible = true; closeText.ZIndex = zb + 3
    table.insert(GUI.RSDiffElements, closeText)
    table.insert(GUI.RSDiffClickables, {
        x = closeX, y = closeY, w = 24, h = 24,
        onClick = function()
            GUI.RSDiffOpen = false
            Tools.ShowRSDiff = false
            ClearRSDiffPanel()
            if GUI.SelectedPage == "Tools" then CreateContent("Tools") end
        end
    })

    -- Action buttons (Snapshot / Compare / Load Saved / Clear)
    local actionY = py + headerH + 6
    local btnH = 28
    local btnGap = 10
    local actionX = px + 14
    local function actionBtn(label, color, onClick, customW)
        local w = customW or 110
        local bgBtn = Drawing.new("Square")
        bgBtn.Position = Vector2.new(actionX, actionY); bgBtn.Size = Vector2.new(w, btnH)
        bgBtn.Color = color; bgBtn.Filled = true; bgBtn.Corner = 4
        bgBtn.Visible = true; bgBtn.ZIndex = zb + 3
        table.insert(GUI.RSDiffElements, bgBtn)
        local txt = Drawing.new("Text")
        txt.Position = Vector2.new(actionX + w / 2, actionY + (btnH - 13) / 1.3 + 0.5)
        txt.Text = label; txt.Color = Color3.fromRGB(220, 220, 230)
        txt.Size = 13; txt.Font = Drawing.Fonts.SystemBold
        txt.Center = true; txt.Outline = false
        txt.Visible = true; txt.ZIndex = zb + 4
        table.insert(GUI.RSDiffElements, txt)
        table.insert(GUI.RSDiffClickables, {
            x = actionX, y = actionY, w = w, h = btnH, onClick = onClick,
        })
        actionX = actionX + w + btnGap
    end

    local hasSnap    = GUI.RSSnapshot ~= nil
    local confirming = GUI.RSOverwriteConfirmAt and (tick() - GUI.RSOverwriteConfirmAt < 3)
    local snapLabel, snapColor
    if confirming then
        snapLabel = "Overwrite?"; snapColor = Color3.fromRGB(180, 60, 60)
    elseif hasSnap then
        snapLabel = "Overwrite"; snapColor = Color3.fromRGB(50, 50, 60)
    else
        snapLabel = "Snapshot"; snapColor = Color3.fromRGB(50, 50, 60)
    end
    actionBtn(snapLabel, snapColor, function()
        if hasSnap and not confirming then
            GUI.RSOverwriteConfirmAt = tick()
            GUI.RSDiffStatus = "Click again within 3s to overwrite."
            BuildRSDiffPanel(); return
        end
        GUI.RSOverwriteConfirmAt = nil
        GUI.RSDiffStatus = "Snapshotting..."
        BuildRSDiffPanel()
        task.spawn(function()
            local snap, count = TakeRSSnapshot()
            GUI.RSSnapshot = snap
            GUI.RSSnapshotCount = count
            local okT, t = pcall(os.time)
            GUI.RSSnapshotAt = okT and t or nil
            GUI.RSDiffResults = nil
            GUI.RSDiffScrollOffset = 0
            local ok, err = saveRSSnapshot()
            if ok then
                GUI.RSDiffStatus = "Snapshot saved: " .. count .. " paths."
            else
                GUI.RSDiffStatus = "Captured " .. count .. " paths, save failed: " .. tostring(err)
            end
            if GUI.RSDiffOpen then BuildRSDiffPanel() end
        end)
    end)

    actionBtn("Compare", Color3.fromRGB(40, 60, 90), function()
        if not GUI.RSSnapshot then
            GUI.RSDiffStatus = "No snapshot. Click 'Snapshot' first."
            BuildRSDiffPanel(); return
        end
        GUI.RSDiffStatus = "Comparing..."
        BuildRSDiffPanel()
        task.spawn(function()
            local cur = TakeRSSnapshot()
            local res = CompareRSSnapshots(GUI.RSSnapshot, cur)
            GUI.RSDiffResults = res
            GUI.RSDiffScrollOffset = 0
            GUI.RSDiffStatus = #res .. " changes since snapshot."
            if GUI.RSDiffOpen then BuildRSDiffPanel() end
        end)
    end)

    actionBtn("Load Saved", Color3.fromRGB(50, 70, 40), function()
        local exists = false
        pcall(function() exists = isfile and isfile(RS_SNAPSHOT_PATH) end)
        if not exists then
            GUI.RSDiffStatus = "No saved snapshot file on disk."
            BuildRSDiffPanel(); return
        end
        GUI.RSDiffStatus = "Loading..."
        BuildRSDiffPanel()
        task.spawn(function()
            loadRSSnapshot()
            if GUI.RSSnapshot then
                GUI.RSDiffStatus = "Loaded " .. (GUI.RSSnapshotCount or 0) .. " paths from disk."
            else
                GUI.RSDiffStatus = "Load failed (see console)."
            end
            if GUI.RSDiffOpen then BuildRSDiffPanel() end
        end)
    end)

    actionBtn("Clear", Color3.fromRGB(80, 40, 40), function()
        GUI.RSDiffResults = nil
        GUI.RSDiffScrollOffset = 0
        GUI.RSDiffStatus = ""
        BuildRSDiffPanel()
    end)

    -- Legend on the right
    local legend = Drawing.new("Text")
    legend.Position = Vector2.new(px + pw - 150, actionY + 8); legend.Text = "ADD  DEL  CLS"
    legend.Color = Colors.TextMuted; legend.Size = 12
    legend.Font = Drawing.Fonts.System; legend.Center = false
    legend.Outline = false; legend.Visible = true; legend.ZIndex = zb + 3
    table.insert(GUI.RSDiffElements, legend)

    -- Separator under action bar
    local sepY = actionY + btnH + 6
    local sep = Drawing.new("Line")
    sep.From = Vector2.new(px + 4, sepY); sep.To = Vector2.new(px + pw - 4, sepY)
    sep.Color = Color3.fromRGB(40, 40, 46); sep.Thickness = 1
    sep.Visible = true; sep.ZIndex = zb + 2
    table.insert(GUI.RSDiffElements, sep)

    -- Results list
    local listY = sepY + 8
    local listX = px + 14
    local listW = pw - 28 - 26
    local listH = ph - (listY - py) - 14
    local rowH = 18
    local maxVisible = math.floor(listH / rowH)

    local results = GUI.RSDiffResults
    if not results then
        local hint = Drawing.new("Text")
        hint.Position = Vector2.new(px + pw / 2, listY + listH / 2 - 8)
        hint.Text = GUI.RSSnapshot
            and "Snapshot stored. Click 'Compare' after the game updates."
            or  "Click 'Snapshot' to record now, or 'Load Saved' to pull the last on-disk snapshot."
        hint.Color = Colors.TextMuted; hint.Size = 13
        hint.Font = Drawing.Fonts.System; hint.Center = true
        hint.Outline = false; hint.Visible = true; hint.ZIndex = zb + 3
        table.insert(GUI.RSDiffElements, hint)
    elseif #results == 0 then
        local hint = Drawing.new("Text")
        hint.Position = Vector2.new(px + pw / 2, listY + listH / 2 - 8)
        hint.Text = "No changes detected since last snapshot."
        hint.Color = Colors.DiffAdd; hint.Size = 14
        hint.Font = Drawing.Fonts.SystemBold; hint.Center = true
        hint.Outline = false; hint.Visible = true; hint.ZIndex = zb + 3
        table.insert(GUI.RSDiffElements, hint)
    else
        local maxOffset = math.max(0, #results - maxVisible)
        if GUI.RSDiffScrollOffset > maxOffset then GUI.RSDiffScrollOffset = maxOffset end
        if GUI.RSDiffScrollOffset < 0 then GUI.RSDiffScrollOffset = 0 end

        for i = 1, math.min(maxVisible, #results - GUI.RSDiffScrollOffset) do
            local r = results[i + GUI.RSDiffScrollOffset]
            if r then
                local yy = listY + (i - 1) * rowH
                local kindLbl = Drawing.new("Text")
                kindLbl.Position = Vector2.new(listX, yy); kindLbl.Text = r.kind
                kindLbl.Color = RS_DIFF_COLORS[r.kind] or Colors.TextPrimary
                kindLbl.Size = 13; kindLbl.Font = Drawing.Fonts.SystemBold
                kindLbl.Center = false; kindLbl.Outline = false; kindLbl.Visible = true; kindLbl.ZIndex = zb + 5
                table.insert(GUI.RSDiffElements, kindLbl)
                local pathLbl = Drawing.new("Text")
                pathLbl.Position = Vector2.new(listX + 36, yy); pathLbl.Text = r.path .. " " .. (r.detail or "")
                pathLbl.Color = Colors.TextPrimary; pathLbl.Size = 12
                pathLbl.Font = Drawing.Fonts.System; pathLbl.Center = false
                pathLbl.Outline = false; pathLbl.Visible = true; pathLbl.ZIndex = zb + 5
                table.insert(GUI.RSDiffElements, pathLbl)
            end
        end

        -- Scroll buttons on the right
        local sbX = px + pw - 14 - 22
        local sbH = 22
        local function sbBtn(yy, label, onClick)
            local bgB = Drawing.new("Square")
            bgB.Position = Vector2.new(sbX, yy); bgB.Size = Vector2.new(22, sbH)
            bgB.Color = Color3.fromRGB(40, 40, 46); bgB.Filled = true; bgB.Corner = 4
            bgB.Visible = true; bgB.ZIndex = zb + 3
            table.insert(GUI.RSDiffElements, bgB)
            local txt = Drawing.new("Text")
            txt.Position = Vector2.new(sbX + 11, yy + (sbH - 13) / 1.3)
            txt.Text = label; txt.Color = Colors.TextPrimary; txt.Size = 13
            txt.Font = Drawing.Fonts.SystemBold; txt.Center = true; txt.Outline = false
            txt.Visible = true; txt.ZIndex = zb + 4
            table.insert(GUI.RSDiffElements, txt)
            table.insert(GUI.RSDiffClickables, { x = sbX, y = yy, w = 22, h = sbH, onClick = onClick })
        end
        sbBtn(listY, "^", function()
            GUI.RSDiffScrollOffset = math.max(0, GUI.RSDiffScrollOffset - maxVisible)
            BuildRSDiffPanel()
        end)
        sbBtn(listY + listH - sbH, "v", function()
            GUI.RSDiffScrollOffset = math.min(maxOffset, GUI.RSDiffScrollOffset + maxVisible)
            BuildRSDiffPanel()
        end)

        local posTxt = Drawing.new("Text")
        posTxt.Position = Vector2.new(sbX + 11, listY + listH / 2 - 8)
        posTxt.Text = string.format("%d-%d/%d",
            GUI.RSDiffScrollOffset + 1,
            math.min(#results, GUI.RSDiffScrollOffset + maxVisible),
            #results)
        posTxt.Color = Colors.TextMuted; posTxt.Size = 10
        posTxt.Font = Drawing.Fonts.System; posTxt.Center = true
        posTxt.Outline = false; posTxt.Visible = true; posTxt.ZIndex = zb + 5
        table.insert(GUI.RSDiffElements, posTxt)
    end
end

