    local sliderW = cardW - Config.CardPad * 2
    local sy = curY + 20
    local fill, knob = DrawSlider(sliderX, sy, value, minV, maxV, sliderW, zb + 3)
    table.insert(GUI.Clickables, {
        x = sliderX - 6, y = sy - 8, w = sliderW + 12, h = Config.SliderH + 16,
        isSlider = true,
        onClick = function(mx)
            local frac = clamp01((mx - sliderX) / sliderW)
            local val = math.floor(minV + frac * (maxV - minV) + 0.5)
            onChange(val)
            local fr = clamp01((val - minV) / (maxV - minV))
