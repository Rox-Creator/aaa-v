local CHAR_W_BOLD = 6.1
local CHAR_W_REG  = 7

-- LIGHTWEIGHT ESP: 5 Drawing objects per player (was ~16). The object count is
-- what costs FPS in Matcha — every property write is a Lua->executor bridge call,
-- so fewer objects = dramatically smoother in populated servers.
--   box    = single Square outline (replaces 8 corner-bracket Lines)
--   name   = Text, Center=true, Outline=true (no background pill needed)
--   dist   = Text, Center=true, Outline=true (no background pill)
--   hpFill = single thin Square bar (no bg, no number pill)
--   tracer = Line
local function makeEspObj(model)
    local box = Drawing.new("Square")
    box.Thickness = 1; box.Filled = false; box.Color = PLAYER_ESP.Color
    box.Visible = false; box.ZIndex = 2
    local name = Drawing.new("Text")
    name.Size = 13; name.Center = true; name.Outline = true; name.Font = Drawing.Fonts.System
    name.Color = PLAYER_ESP.Color; name.Visible = false; name.ZIndex = 3
    local dist = Drawing.new("Text")
    dist.Size = 12; dist.Center = true; dist.Outline = true; dist.Font = Drawing.Fonts.System
    dist.Color = PLAYER_ESP.Color; dist.Visible = false; dist.ZIndex = 3
    local hpFill = Drawing.new("Square")
    hpFill.Filled = true; hpFill.Color = Color3.fromRGB(60, 220, 80)
    hpFill.Visible = false; hpFill.ZIndex = 2
    local hpNum = Drawing.new("Text")
    hpNum.Size = 12; hpNum.Center = true; hpNum.Outline = true; hpNum.Font = Drawing.Fonts.System
    hpNum.Color = Color3.fromRGB(60, 220, 80); hpNum.Visible = false; hpNum.ZIndex = 3
    local tracer = Drawing.new("Line")
    tracer.Thickness = 1; tracer.Color = PLAYER_ESP.Color; tracer.Visible = false; tracer.ZIndex = 1
    return { model = model, hrp = nil, hum = nil, displayName = nil,
             box = box, name = name, dist = dist, hpFill = hpFill, hpNum = hpNum, tracer = tracer, cache = {} }
end

local function hideEspObj(o)
    -- Already fully hidden last frame? Do nothing — common case for culled/offscreen
    -- players, so guarding it saves a ton of redundant bridge writes.
    if o.cache.hidden then return end
    o.cache.hidden = true
    pcall(function()
        o.box.Visible = false
        o.name.Visible = false; o.dist.Visible = false
        o.hpFill.Visible = false; o.hpNum.Visible = false
        o.tracer.Visible = false
    end)
    o.cache.boxVis, o.cache.nameVis, o.cache.distVis = false, false, false
    o.cache.hpFillVis, o.cache.hpNumVis, o.cache.tracerVis = false, false, false
end
local function removeEspObj(o)
    pcall(function() o.box:Remove() end)
    pcall(function() o.name:Remove() end)
    pcall(function() o.dist:Remove() end)
    pcall(function() o.hpFill:Remove() end)
    pcall(function() o.hpNum:Remove() end)
    pcall(function() o.tracer:Remove() end)
end
-- These run in the per-player hot loop which is wrapped in a single pcall,
-- so they use direct assignment (no per-call closure allocation).
local function setVis(o, el, key, want)
    if o.cache[key] ~= want then o.cache[key] = want; el.Visible = want end
end

-- Key ESP objects by player NAME (not model reference). When a player
-- respawns, the model reference changes but the name stays — we just
-- update o.model in place and keep all Drawing elements alive.
-- No tear-down + rebuild = no flicker.
local function espScan()
    local world = Workspace:FindFirstChild("World")
    local chars = world and world:FindFirstChild("Characters")
    if not chars then return end
    local present = {}
    for _, model in ipairs(chars:GetChildren()) do
        if model.Name ~= LocalPlayer.Name and (model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart) then
            local key = model.Name
            present[key] = true
            local existing = PLAYER_ESP.Objects[key]
            if existing then
                -- Update model ref on respawn, but keep Drawing elements
                if existing.model ~= model then
                    existing.model = model
                    existing.hrp = nil  -- force re-cache HRP from new model
                    existing.hum = nil
                    existing.displayName = nil
                    existing.smoothPos = nil  -- snap to new spawn pos, don't slide across screen
                end
            else
                local newObj = makeEspObj(model)
                PLAYER_ESP.Objects[key] = newObj
            end
        end
    end
    -- Only remove ESP for players whose name actually left the folder
    for key, o in pairs(PLAYER_ESP.Objects) do
        if not present[key] then removeEspObj(o); PLAYER_ESP.Objects[key] = nil end
    end
end

local function espUpdate()
    if not Features.PlayerESP then
        for _, o in pairs(PLAYER_ESP.Objects) do hideEspObj(o) end
        return
    end
    local myPos = localRootPos()
    local col = PLAYER_ESP.Color
    local vpW, vpH = 2560, 1440
    pcall(function() local c = Workspace.CurrentCamera; vpW, vpH = c.ViewportSize.X, c.ViewportSize.Y end)

    -- Count objects + clear cull flags in one cheap pass (no position reads).
    local MAX_RENDER = PLAYER_ESP.MaxRender or 22
    local count = 0
    for _, o in pairs(PLAYER_ESP.Objects) do o._culled = false; count = count + 1 end

    -- Only run the closest-N cull pre-pass when the server actually has more
    -- players than the cap. In normal servers this whole block is skipped — no
    -- per-frame distance reads / sort / table allocation.
    if count > MAX_RENDER and myPos then
        local list = {}
        for _, o in pairs(PLAYER_ESP.Objects) do
            local m = o.model
            if m and m.Parent then
                local hrp = o.hrp
                if not hrp or not hrp.Parent then
                    hrp = m:FindFirstChild("HumanoidRootPart") or m.PrimaryPart
                    o.hrp = hrp
                end
                if hrp then
                    local ok, p = pcall(function() return hrp.Position end)
                    if ok and p then list[#list + 1] = { o = o, d = (p - myPos).Magnitude } end
                end
            end
        end
        if #list > MAX_RENDER then
            table.sort(list, function(a, b) return a.d < b.d end)
            for i = MAX_RENDER + 1, #list do list[i].o._culled = true end
        end
    end

    for key, o in pairs(PLAYER_ESP.Objects) do
        local model = o.model
        local hide = false
        -- Culled (beyond the closest-N cap) → hide and skip all the expensive
        -- box/name/hp drawing for this player this frame.
        if o._culled then
            hide = true
        -- If model briefly has no Parent (between respawn frames), skip this
        -- frame entirely instead of hiding+rebuilding visuals.
        elseif not model or not model.Parent then
            -- Don't hide — just leave the ESP elements where they were last frame.
            -- The next scan tick will update o.model to the new respawn model.
        else
            -- Entire per-player visual update runs in ONE pcall instead of ~18
            -- inner pcall closures. Eliminating that per-frame closure storm is
            -- the main perf/GC win in populated servers. setVis/setBox/setLine
            -- use direct assignment now (they're protected by this outer pcall).
            local ok = pcall(function()
                local hrp = o.hrp
                if not hrp or not hrp.Parent then
                    hrp = model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart
                    o.hrp = hrp
                end
                local pos = hrp and hrp.Position or nil
                if not pos then hide = true; return end

                -- Position smoothing — lerp toward the real position so choppy
                -- server updates glide instead of snapping. Snap on big jumps.
                if o.smoothPos and (o.smoothPos - pos).Magnitude < 40 then
                    o.smoothPos = o.smoothPos:Lerp(pos, 0.45)
                else
                    o.smoothPos = pos
                end
                pos = o.smoothPos
                local d = myPos and (pos - myPos).Magnitude or nil
                if d and d > PLAYER_ESP.MaxDistance then hide = true; return end

                local headS, onHead = WorldToScreen(pos + Vector3.new(0, 3, 0))
                local footS, onFoot = WorldToScreen(pos - Vector3.new(0, 3, 0))
                -- Only hide if FULLY off-screen (allow partial so it doesn't pop).
                if not (headS and footS) or (not onHead and not onFoot) then hide = true; return end

                o.cache.hidden = nil  -- visible again (lets hideEspObj fire later)
                local cache = o.cache
                if cache.col ~= col then
                    cache.col = col
                    o.box.Color = col; o.name.Color = col; o.dist.Color = col; o.tracer.Color = col
                end
                local topY = headS.Y
                local boxH = footS.Y - topY
                local boxW = boxH * 0.42
                local centerX = (headS.X + footS.X) / 2
                local boxX = centerX - boxW / 2

                -- Box: single Square outline (1 object instead of 8 lines)
                if PLAYER_ESP.ShowBox and boxH > 0 then
                    o.box.Position = Vector2.new(boxX, topY)
                    o.box.Size = Vector2.new(boxW, boxH)
                    setVis(o, o.box, "boxVis", true)
                else setVis(o, o.box, "boxVis", false) end

                if not o.displayName then
                    local fn = model:GetAttribute("FirstName")
                    if fn == nil then
                        local fc = model:FindFirstChild("FirstName")
                        if fc then fn = fc.Value end
                    end
                    if type(fn) == "string" and fn ~= "" then
                        o.displayName = fn .. " (" .. model.Name .. ")"
                    end
                end

                -- Name: centered + outlined text above the box (no background pill)
                local nameStr = PLAYER_ESP.ShowName and (o.displayName or model.Name) or ""
                if nameStr ~= "" then
                    o.name.Position = Vector2.new(centerX, topY - 16)
                    if cache.nameTxt ~= nameStr then cache.nameTxt = nameStr; o.name.Text = nameStr end
                    setVis(o, o.name, "nameVis", true)
                else setVis(o, o.name, "nameVis", false) end

                -- Health: thin vertical bar left of the box + a number. Compute first
                -- so the number can join the stacked text below the box.
                local showHp = PLAYER_ESP.ShowHealthBar and boxH > 4
                local hpStr, hpColor
                if showHp then
                    local hum = o.hum
                    if not hum or not hum.Parent then
                        hum = model:FindFirstChildWhichIsA("Humanoid")
                        o.hum = hum
                    end
                    local hp, maxHp = 1, 1
                    if hum then hp = hum.Health; maxHp = hum.MaxHealth end
                    local pct = maxHp > 0 and math.max(0, math.min(1, hp / maxHp)) or 0
                    hpColor = Color3.fromRGB(math.floor(255 * (1 - pct)), math.floor(220 * pct), 60)
                    local barW = 3
                    local barX = boxX - barW - 3
                    local fillH = boxH * pct
                    o.hpFill.Position = Vector2.new(barX, topY + (boxH - fillH))
                    o.hpFill.Size = Vector2.new(barW, fillH)
                    o.hpFill.Color = hpColor
                    setVis(o, o.hpFill, "hpFillVis", true)
                    hpStr = tostring(math.floor(hp))
                else
                    setVis(o, o.hpFill, "hpFillVis", false)
                end

                -- Stack centered+outlined text below the box: distance, then HP number.
                local belowY = footS.Y + 1
                local distStr = (PLAYER_ESP.ShowDistance and d) and (math.floor(d + 0.5) .. "m") or ""
                if distStr ~= "" then
                    o.dist.Position = Vector2.new(centerX, belowY)
                    if cache.distTxt ~= distStr then cache.distTxt = distStr; o.dist.Text = distStr end
                    setVis(o, o.dist, "distVis", true)
                    belowY = belowY + 13
                else setVis(o, o.dist, "distVis", false) end
                if showHp then
                    o.hpNum.Position = Vector2.new(centerX, belowY)
                    if cache.hpNumTxt ~= hpStr then cache.hpNumTxt = hpStr; o.hpNum.Text = hpStr end
                    o.hpNum.Color = hpColor
                    setVis(o, o.hpNum, "hpNumVis", true)
                else setVis(o, o.hpNum, "hpNumVis", false) end

                if PLAYER_ESP.ShowTracer then
                    o.tracer.From = Vector2.new(vpW / 2, vpH)
                    o.tracer.To = Vector2.new(centerX, footS.Y)
                    setVis(o, o.tracer, "tracerVis", true)
                else setVis(o, o.tracer, "tracerVis", false) end
            end)
            if not ok then hide = true end
        end
        if hide then hideEspObj(o) end
    end
end

