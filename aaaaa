    task.spawn(function()
        for s = 1, 10 do
            if not isAnimCurrent(token) then return end
            local et = 1 - (1 - s / 10) ^ 3
            pcall(function()
                under.From = Vector2.new(fromL + (toL - fromL) * et, lineY)
                under.To   = Vector2.new(fromR + (toR - fromR) * et, lineY)
            end)
            task.wait(0.016)
