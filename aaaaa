ClearSubTabs = function()
    for _, el in ipairs(GUI.SubTabElements) do pcall(function() el:Remove() end) end
    GUI.SubTabElements = {}
    GUI.SubTabClickables = {}
end

CreateSubTabs = function()
    ClearSubTabs()
    if GUI.SelectedPage ~= "Main" then return end
    local barY = Config.WinY + Config.HeaderH
    local halfW = Config.WinW / 2
    local zb = 8
    local glowX = (GUI.SubTab == "Style") and (Config.WinX + halfW) or Config.WinX
