    Unknown            = Color3.fromRGB(100, 100, 110),
}
local ENCHANT_RARITIES_ORDER = {
    "Common","Uncommon","Rare","Epic","Legendary","Lore","Holy","Unique","Staff",
    "Voyager","Bulwark","Champion","Wise","Savior",
    "Unknown",
}

-- Map a folder/template name to a rarity bucket (best-effort).
local function bucketFromFolderName(folderName)
    if not folderName then return "Unknown" end
    local nl = folderName:lower()
    if nl:find("legendary") then return "Legendary" end
    if nl:find("epic")      then return "Epic" end
    if nl:find("mythic")    then return "Mythic" end
    if nl:find("lore")      then return "Lore" end
    if nl:find("uncommon")  then return "Uncommon" end
    if nl:find("rare")      then return "Rare" end
    if nl:find("common")    then return "Common" end
    -- Path talents are typically Legendary-tier endgame
    if nl:find("path")      then return "Legendary" end
    -- Unique talents map to Mythic
    if nl:find("unique")    then return "Mythic" end
    if ENCHANT_RARITY_COLORS[folderName] then return folderName end
    return "Unknown"
end

-- Climb ancestors looking for a folder name that maps to a rarity bucket.
local function enchantRarityFromAncestors(inst)
    local cur = inst.Parent
    while cur and cur ~= game do
        local b = bucketFromFolderName(cur.Name)
        if b ~= "?" then return b end
        cur = cur.Parent
    end
    return "?"
end

